@model TravelERP.Core.Entities.Tenant.MailTemplate
@{
    ViewData["Title"] = "Add Mail Template";
    var categories = ViewBag.Categories as string[] ?? [];
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
    <style>
        .quill-host { background:#fff; border-radius: 0 0 .375rem .375rem; }
        .quill-host .ql-toolbar { border-radius: .375rem .375rem 0 0; }
        .quill-host .ql-container { min-height: 320px; font-size: .9rem; }
        .placeholders code { background: var(--bs-light); padding: 1px 6px; border-radius: 3px;
                             font-size: .8rem; cursor: pointer; }
    </style>
}

<form asp-action="Create" method="post" id="tmplForm">
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-envelope-paper text-primary me-2"></i>Template Details</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-7">
                    <label asp-for="Name" class="form-label small fw-semibold">Template Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Booking Confirmation Email" autofocus />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-5">
                    <label asp-for="Category" class="form-label small fw-semibold">Category</label>
                    <select asp-for="Category" class="form-select">
                        <option value="">— None —</option>
                        @foreach (var c in categories)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-12">
                    <label asp-for="Subject" class="form-label small fw-semibold">Subject <span class="text-danger">*</span></label>
                    <input asp-for="Subject" class="form-control" placeholder="e.g. Your booking is confirmed!" />
                    <span asp-validation-for="Subject" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-text-paragraph text-primary me-2"></i>Email Body</h6>
        </div>
        <div class="card-body p-3">
            <input type="hidden" asp-for="Body" id="Body" />
            <div class="quill-host"><div id="bodyEditor"></div></div>
            <div class="placeholders mt-2 small text-muted">
                Available placeholders (click to copy):
                <code class="ph">{{customer_name}}</code>
                <code class="ph">{{booking_id}}</code>
                <code class="ph">{{package_name}}</code>
                <code class="ph">{{travel_date}}</code>
                <code class="ph">{{amount}}</code>
                <code class="ph">{{company_name}}</code>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a href="/MailTemplates" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-1"></i>Save Template
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
    <script>
        const toolbar = [
            [{ header: [false, 1, 2, 3] }],
            ['bold', 'italic', 'underline'],
            [{ list: 'ordered' }, { list: 'bullet' }],
            [{ indent: '-1' }, { indent: '+1' }],
            ['link', 'clean']
        ];
        const bodyQuill = new Quill('#bodyEditor', { theme: 'snow', modules: { toolbar } });

        document.querySelectorAll('.ph').forEach(el => {
            el.addEventListener('click', () => {
                navigator.clipboard?.writeText(el.textContent);
                el.style.background = '#cfe2ff';
                setTimeout(() => el.style.background = '', 600);
            });
        });

        document.getElementById('tmplForm').addEventListener('submit', () => {
            document.getElementById('Body').value = bodyQuill.root.innerHTML;
        });
    </script>
}
