@model IEnumerable<TravelERP.Core.Entities.Tenant.Invoice>
@using TravelERP.Shared.Enums
@{
    ViewData["Title"] = "Invoices";
    var sym = ViewBag.CurrencySymbol as string ?? "";
}
<div class="card shadow-sm">
    <div class="card-header bg-transparent border-0 section-header">
        <h5><i class="bi bi-receipt text-primary me-2"></i>Invoices &amp; Payments</h5>
    </div>
    <div class="card-body">
        <table class="table table-hover dt-table">
            <thead>
                <tr>
                    <th>Invoice #</th><th>Booking Ref</th><th>Customer</th>
                    <th>Date</th><th>Due</th><th>Total</th><th>Paid</th><th>Balance</th><th>Status</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in Model)
                {
                    var balance = inv.TotalAmount - inv.PaidAmount;
                    <tr>
                        <td><a href="/Finance/Invoice/@inv.Id" class="fw-semibold text-decoration-none">@inv.InvoiceNumber</a></td>
                        <td>@inv.BookingId</td>
                        <td>@inv.CustomerId</td>
                        <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                        <td class="@(inv.DueDate < DateTime.Today && inv.Status != InvoiceStatus.Paid ? "text-danger fw-semibold" : "")">
                            @inv.DueDate.ToString("dd MMM yyyy")
                        </td>
                        <td>@sym@inv.TotalAmount.ToString("N2")</td>
                        <td class="text-success">@sym@inv.PaidAmount.ToString("N2")</td>
                        <td class="@(balance > 0 ? "text-danger fw-semibold" : "text-success")">
                            @sym@balance.ToString("N2")
                        </td>
                        <td>
                            <span class="badge @GetBadge(inv.Status)">@inv.Status</span>
                        </td>
                        <td>
                            <a href="/Finance/Invoice/@inv.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            @if (inv.Status != InvoiceStatus.Paid)
                            {
                                <a href="/Finance/AddPayment/@inv.Id" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-cash-coin"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetBadge(InvoiceStatus s) => s switch {
        InvoiceStatus.Paid    => "bg-success",
        InvoiceStatus.Overdue => "bg-danger",
        InvoiceStatus.Sent    => "bg-info",
        InvoiceStatus.Draft   => "bg-secondary",
        _                     => "bg-secondary"
    };
}
