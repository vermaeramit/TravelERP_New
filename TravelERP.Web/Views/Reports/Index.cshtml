@{
    ViewData["Title"] = "Reports";
}
<div class="row g-3">
    <div class="col-md-4">
        <a href="/Reports/Revenue" class="text-decoration-none">
            <div class="card shadow-sm stat-card h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-graph-up-arrow fs-1 text-success mb-3 d-block"></i>
                    <h5 class="fw-bold">Revenue Report</h5>
                    <p class="text-muted small mb-0">Monthly & yearly revenue breakdown, top performing packages</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Reports/Bookings" class="text-decoration-none">
            <div class="card shadow-sm stat-card h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-journal-bookmark-fill fs-1 text-primary mb-3 d-block"></i>
                    <h5 class="fw-bold">Bookings Report</h5>
                    <p class="text-muted small mb-0">Booking details by date range, status, agent</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm stat-card h-100 opacity-50">
            <div class="card-body text-center py-4">
                <i class="bi bi-person-lines-fill fs-1 text-info mb-3 d-block"></i>
                <h5 class="fw-bold">HR Report</h5>
                <p class="text-muted small mb-0">Employee summary, leave statistics <span class="badge bg-secondary">Coming soon</span></p>
            </div>
        </div>
    </div>
</div>
