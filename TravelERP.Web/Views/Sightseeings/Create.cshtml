@model TravelERP.Core.Entities.Tenant.Sightseeing
@{
    ViewData["Title"] = "Add Sightseeing";
    var destinations = ViewBag.Destinations as IEnumerable<TravelERP.Core.Entities.Tenant.Destination> ?? [];
}

@section Styles {
    <style>
        .img-preview { width: 100%; max-width: 220px; aspect-ratio: 16/9; object-fit: cover;
                       border-radius: .375rem; border: 1px solid var(--bs-border-color); }
        .img-placeholder { width: 100%; max-width: 220px; aspect-ratio: 16/9;
                           border: 2px dashed var(--bs-border-color); border-radius: .375rem;
                           display: flex; align-items: center; justify-content: center;
                           color: var(--bs-secondary-color); }
    </style>
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-camera text-primary me-2"></i>Sightseeing Details</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="DestinationId" class="form-label small fw-semibold">Destination <span class="text-danger">*</span></label>
                            <select asp-for="DestinationId" class="form-select dest-select">
                                <option value="">Select Destination</option>
                                @foreach (var d in destinations)
                                {
                                    <option value="@d.Id">@d.Name</option>
                                }
                            </select>
                            <span asp-validation-for="DestinationId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label small fw-semibold">Sightseeing Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Eiffel Tower" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Image <span class="text-muted">(1366×768)</span></label>
                    <input type="file" name="heroImage" accept="image/*" class="form-control hero-input" />
                    <div class="mt-2">
                        <div class="img-placeholder hero-placeholder">
                            <i class="bi bi-image fs-3"></i>
                        </div>
                        <img class="img-preview hero-preview d-none" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a href="/Sightseeings" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-1"></i>Save Sightseeing
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $('.dest-select').select2({ theme: 'bootstrap-5', width: '100%' });
        const heroInput = document.querySelector('.hero-input');
        const heroPreview = document.querySelector('.hero-preview');
        const heroPlaceholder = document.querySelector('.hero-placeholder');
        heroInput.addEventListener('change', e => {
            const f = e.target.files?.[0]; if (!f) return;
            heroPreview.src = URL.createObjectURL(f);
            heroPreview.classList.remove('d-none');
            heroPlaceholder.classList.add('d-none');
        });
    </script>
}
