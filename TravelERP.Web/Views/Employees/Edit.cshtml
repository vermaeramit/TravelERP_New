@model TravelERP.Web.Controllers.EmployeesController.EmployeeFormVm
@{
    ViewData["Title"] = $"Edit — {Model.FirstName} {Model.LastName}".Trim();
    var designations = ViewBag.Designations as IEnumerable<TravelERP.Core.Entities.Tenant.Designation> ?? [];
    var roles = ViewBag.Roles as IEnumerable<TravelERP.Core.Entities.Tenant.Role> ?? [];
}

@section Styles {
    <style>
        .img-preview { width: 96px; height: 96px; object-fit: cover; border-radius: 50%;
                       border: 1px solid var(--bs-border-color); }
        .img-placeholder { width: 96px; height: 96px; border: 2px dashed var(--bs-border-color);
                           border-radius: 50%; display: flex; align-items: center; justify-content: center;
                           color: var(--bs-secondary-color); }
    </style>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-person-badge text-primary me-2"></i>Employee Details</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-9">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="DesignationId" class="form-label small fw-semibold">Designation</label>
                            <select asp-for="DesignationId" class="form-select role-select">
                                <option value="">Select</option>
                                @foreach (var d in designations)
                                {
                                    <option value="@d.Id" selected="@(d.Id == Model.DesignationId)">@d.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label small fw-semibold">First Name <span class="text-danger">*</span></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label small fw-semibold">Last Name</label>
                            <input asp-for="LastName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label small fw-semibold">Email (CRM Login) <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Mobile" class="form-label small fw-semibold">Mobile</label>
                            <input asp-for="Mobile" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="col-md-3 text-center">
                    <label class="form-label small fw-semibold d-block">Photo <span class="text-muted">(80×80)</span></label>
                    <div class="d-flex flex-column align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="img-placeholder photo-placeholder d-none"><i class="bi bi-person fs-3"></i></div>
                            <img class="img-preview photo-preview" src="@Model.ImageUrl" />
                        }
                        else
                        {
                            <div class="img-placeholder photo-placeholder"><i class="bi bi-person fs-3"></i></div>
                            <img class="img-preview photo-preview d-none" />
                        }
                        <input type="file" name="photo" accept="image/*" class="form-control form-control-sm photo-input" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-shield-lock text-primary me-2"></i>Login &amp; Profile</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="DateOfBirth" class="form-label small fw-semibold">Date of Birth</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-4">
                    <label asp-for="ReplyEmail" class="form-label small fw-semibold">Reply-To Email</label>
                    <input asp-for="ReplyEmail" type="email" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="TenantRoleId" class="form-label small fw-semibold">Role</label>
                    <select asp-for="TenantRoleId" class="form-select role-select">
                        <option value="">Select Role</option>
                        @foreach (var r in roles)
                        {
                            <option value="@r.Id" selected="@(r.Id == Model.TenantRoleId)">@r.RoleName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label small fw-semibold">New Password <span class="text-muted">(leave blank to keep)</span></label>
                    <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a href="/Employees" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-1"></i>Update Employee
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $('.role-select').select2({ theme: 'bootstrap-5', width: '100%' });

        const photoInput = document.querySelector('.photo-input');
        const photoPreview = document.querySelector('.photo-preview');
        const photoPlaceholder = document.querySelector('.photo-placeholder');
        photoInput.addEventListener('change', e => {
            const f = e.target.files?.[0]; if (!f) return;
            photoPreview.src = URL.createObjectURL(f);
            photoPreview.classList.remove('d-none');
            photoPlaceholder.classList.add('d-none');
        });
    </script>
}
