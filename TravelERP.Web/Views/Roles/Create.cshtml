@model TravelERP.Core.Entities.Tenant.Role
@{ ViewData["Title"] = "New Role"; }

<form asp-action="Create" asp-controller="Roles" method="post">
    @Html.AntiForgeryToken()
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-shield-plus text-primary me-2"></i>Role Details</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="RoleName" class="form-label small fw-semibold">Role Name</label>
                    <input asp-for="RoleName" class="form-control" placeholder="e.g. Sales Manager" autofocus />
                    <span asp-validation-for="RoleName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Description" class="form-label small fw-semibold">Description</label>
                    <input asp-for="Description" class="form-control" placeholder="Brief description" />
                </div>
                <div class="col-12">
                    <div class="form-check form-switch border rounded p-3 ps-5 bg-light">
                        <input asp-for="OnlyAssigned" class="form-check-input" type="checkbox" id="OnlyAssigned" />
                        <label class="form-check-label fw-semibold" for="OnlyAssigned">
                            <i class="bi bi-funnel text-primary me-1"></i>
                            Restrict to assigned data only
                        </label>
                        <div class="small text-muted mt-1">
                            When enabled, users in this role only see leads assigned to them and bookings linked to those leads
                            — across the Leads list, Bookings list, Today panel, and Dashboard.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-toggles text-primary me-2"></i>Module Permissions</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:240px">Module</th>
                            <th class="text-center">View</th>
                            <th class="text-center">Add</th>
                            <th class="text-center">Edit</th>
                            <th class="text-center">Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var grp in ((string Section, string[] Modules)[])ViewBag.Sections)
                        {
                            <tr class="table-light">
                                <td colspan="5" class="fw-bold small text-uppercase text-muted ps-3" style="letter-spacing:.05em">@grp.Section</td>
                            </tr>
                            @foreach (var module in grp.Modules)
                            {
                                <tr>
                                    <td class="fw-semibold small ps-4">@module</td>
                                    <td class="text-center"><input type="checkbox" name="View[@module]"   value="true" class="form-check-input perm-check" /></td>
                                    <td class="text-center"><input type="checkbox" name="Add[@module]"    value="true" class="form-check-input perm-check" /></td>
                                    <td class="text-center"><input type="checkbox" name="Edit[@module]"   value="true" class="form-check-input perm-check" /></td>
                                    <td class="text-center"><input type="checkbox" name="Delete[@module]" value="true" class="form-check-input perm-check" /></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a href="/Roles" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-1"></i>Create Role
        </button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
