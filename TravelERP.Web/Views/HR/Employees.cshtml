@model IEnumerable<TravelERP.Core.Entities.Tenant.Employee>
@using TravelERP.Shared.Enums
@{
    ViewData["Title"] = "Employees";
}
<div class="card shadow-sm">
    <div class="card-header bg-transparent border-0 section-header">
        <h5><i class="bi bi-person-lines-fill text-primary me-2"></i>Employee Directory</h5>
        <a href="/HR/Employee/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Add Employee
        </a>
    </div>
    <div class="card-body">
        <table class="table table-hover dt-table">
            <thead>
                <tr>
                    <th>Code</th><th>Name</th><th>Department</th><th>Designation</th>
                    <th>Email</th><th>Phone</th><th>Joined</th><th>Status</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td><span class="badge bg-light text-dark border">@e.EmployeeCode</span></td>
                        <td><a href="/HR/Employee/@e.Id" class="fw-semibold text-decoration-none">@e.FullName</a></td>
                        <td>@e.Department</td>
                        <td>@e.Designation</td>
                        <td>@e.Email</td>
                        <td>@e.Phone</td>
                        <td>@e.JoiningDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge @(e.Status == EmploymentStatus.Active ? "bg-success" : "bg-secondary")">@e.Status</span>
                        </td>
                        <td>
                            <a href="/HR/Employee/@e.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a href="/HR/Employee/@e.Id/Edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
