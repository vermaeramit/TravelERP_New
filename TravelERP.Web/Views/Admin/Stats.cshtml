@model TravelERP.Web.Controllers.AdminController.AdminStatsVm
@{ ViewData["Title"] = "Platform Overview"; }

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Total Companies</div>
                <div class="fs-2 fw-bold text-primary">@Model.Counters.TotalCompanies</div>
                <div class="small text-muted">@Model.Counters.Signups30d new in last 30 days</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Active</div>
                <div class="fs-2 fw-bold text-success">@Model.Counters.ActiveCount</div>
                <div class="small text-muted">paying tenants</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Trial / Expired</div>
                <div class="fs-2 fw-bold text-warning">@Model.Counters.TrialCount / @Model.Counters.ExpiredCount</div>
                <div class="small text-muted">@Model.Counters.SuspendedCount suspended</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small text-uppercase">MRR (Active)</div>
                <div class="fs-2 fw-bold text-info">$@Model.Counters.MRR.ToString("N0")</div>
                <div class="small text-muted">monthly recurring</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-transparent border-0 fw-bold">
                <i class="bi bi-pie-chart me-1"></i>Companies by Plan
            </div>
            <ul class="list-group list-group-flush">
                @if (!Model.PlanBreakdown.Any())
                {
                    <li class="list-group-item text-muted">No data.</li>
                }
                @foreach (var p in Model.PlanBreakdown)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@p.PlanName</span>
                        <strong>@p.CompanyCount</strong>
                    </li>
                }
            </ul>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-transparent border-0 fw-bold">
                <i class="bi bi-clock-history me-1"></i>Recent Signups
            </div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Company</th>
                            <th>Plan</th>
                            <th>Status</th>
                            <th>Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.RecentSignups.Any())
                        {
                            <tr><td colspan="4" class="text-muted">No signups yet.</td></tr>
                        }
                        @foreach (var c in Model.RecentSignups)
                        {
                            <tr>
                                <td>
                                    <a href="/Admin/Companies/Edit/@c.Id" class="text-decoration-none fw-semibold">@c.Name</a>
                                    <div class="small text-muted">@c.Slug</div>
                                </td>
                                <td><span class="badge bg-secondary-subtle text-secondary">@c.PlanName</span></td>
                                <td><span class="badge bg-light text-dark border">@c.Status</span></td>
                                <td class="small">@c.CreatedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
