@using TravelERP.Shared.DTOs
@{
    ViewData["Title"] = "Dashboard";
    var stats = (DashboardStatsDto)ViewBag.Stats;
    var recent = (IEnumerable<RecentBookingDto>)ViewBag.RecentBookings;
    var topPkgs = (IEnumerable<TopPackageDto>)ViewBag.TopPackages;
    var monthly = (IEnumerable<MonthlyRevenueDto>)ViewBag.MonthlyRevenue;
    var statusChart = (IEnumerable<BookingStatusChartDto>)ViewBag.StatusChart;
    var sym = (string)ViewBag.CurrencySymbol;
}

<!-- KPI STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-journal-bookmark-fill"></i>
                </div>
                <div>
                    <div class="stat-value text-primary">@stats.TotalBookings</div>
                    <div class="stat-label text-muted">Total Bookings</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-currency-rupee"></i>
                </div>
                <div>
                    <div class="stat-value text-success">@sym@stats.TotalRevenue.ToString("N0")</div>
                    <div class="stat-label text-muted">Total Revenue</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <div class="stat-value text-info">@stats.TotalCustomers</div>
                    <div class="stat-label text-muted">Customers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-receipt-cutoff"></i>
                </div>
                <div>
                    <div class="stat-value text-warning">@sym@stats.OutstandingAmount.ToString("N0")</div>
                    <div class="stat-label text-muted">Outstanding</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SECONDARY STATS -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-primary">@stats.ActiveBookings</div>
            <div class="small text-muted">Active Bookings</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-success">@stats.TotalPackages</div>
            <div class="small text-muted">Tour Packages</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-info">@stats.TotalEmployees</div>
            <div class="small text-muted">Employees</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center py-3">
            <div class="fw-bold fs-4 @(stats.PendingLeaves > 0 ? "text-danger" : "text-muted")">
                @stats.PendingLeaves
            </div>
            <div class="small text-muted">Pending Leaves</div>
        </div>
    </div>
</div>

<!-- CHARTS ROW -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Monthly Revenue (@DateTime.Now.Year)</h6>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="90"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-transparent border-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-pie-chart-fill text-info me-2"></i>Bookings by Status</h6>
            </div>
            <div class="card-body d-flex flex-column align-items-center">
                <canvas id="statusPie" height="160"></canvas>
                <div class="mt-3 w-100">
                    @foreach (var s in statusChart)
                    {
                        <div class="d-flex justify-content-between small mb-1">
                            <span><i class="bi bi-circle-fill me-1" style="color:@s.Color"></i>@s.Status</span>
                            <strong>@s.Count</strong>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- RECENT BOOKINGS + TOP PACKAGES -->
<div class="row g-3">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history text-primary me-2"></i>Recent Bookings</h6>
                <a href="/Bookings" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Reference</th>
                                <th>Customer</th>
                                <th>Destination</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in recent)
                            {
                                <tr>
                                    <td><a href="/Bookings/Details/@b.Id" class="fw-semibold text-decoration-none">@b.BookingReference</a></td>
                                    <td>@b.CustomerName</td>
                                    <td class="text-truncate" style="max-width:120px">@b.Destination</td>
                                    <td>@sym@b.TotalAmount.ToString("N0")</td>
                                    <td>
                                        <span class="badge rounded-pill @GetStatusBadge(b.Status)">@b.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold"><i class="bi bi-trophy-fill text-warning me-2"></i>Top Packages</h6>
                <a href="/Packages" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @foreach (var (pkg, i) in topPkgs.Select((p, i) => (p, i + 1)))
                {
                    <div class="d-flex align-items-center px-3 py-2 border-bottom">
                        <span class="badge rounded-pill bg-primary me-3">@i</span>
                        <div class="flex-grow-1">
                            <div class="fw-semibold small">@pkg.Name</div>
                            <div class="text-muted" style="font-size:0.75rem">@pkg.Destination</div>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold small text-success">@sym@pkg.TotalRevenue.ToString("N0")</div>
                            <div class="text-muted" style="font-size:0.75rem">@pkg.BookingCount bookings</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Monthly Revenue Chart
    const mLabels = [@Html.Raw(string.Join(",", monthly.Select(m => $"'{m.MonthName.Substring(0,3)}'")))]
    const mData = [@Html.Raw(string.Join(",", monthly.Select(m => m.Revenue)))]

    new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
            labels: mLabels,
            datasets: [{
                label: 'Revenue',
                data: mData,
                backgroundColor: 'rgba(13,110,253,0.7)',
                borderColor: '#0d6efd',
                borderWidth: 1,
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                x: { grid: { display: false } }
            }
        }
    });

    // Status Pie Chart
    const sLabels = [@Html.Raw(string.Join(",", statusChart.Select(s => $"'{s.Status}'")))]
    const sData   = [@Html.Raw(string.Join(",", statusChart.Select(s => s.Count)))]
    const sColors = [@Html.Raw(string.Join(",", statusChart.Select(s => $"'{s.Color}'")))]

    new Chart(document.getElementById('statusPie'), {
        type: 'doughnut',
        data: { labels: sLabels, datasets: [{ data: sData, backgroundColor: sColors, borderWidth: 2 }] },
        options: { responsive: true, cutout: '65%', plugins: { legend: { display: false } } }
    });
</script>
}

@functions {
    string GetStatusBadge(string status) => status switch {
        "Confirmed" => "bg-success",
        "Pending"   => "bg-warning text-dark",
        "Cancelled" => "bg-danger",
        "Completed" => "bg-primary",
        "Refunded"  => "bg-secondary",
        _           => "bg-light text-dark"
    };
}
