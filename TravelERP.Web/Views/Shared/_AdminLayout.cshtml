@{
    string Active(string controllerOrAction)
    {
        var current = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
        var path = (Context.Request.Path.Value ?? "").ToLowerInvariant();
        return path.Contains("/admin/" + controllerOrAction.ToLowerInvariant()) || current == controllerOrAction.ToLowerInvariant()
            ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Platform Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        body { background:#0f172a; color:#e2e8f0; min-height: 100vh; }
        .admin-shell { display:flex; min-height:100vh; }
        .admin-side {
            width: 240px; background: #1e293b; color:#cbd5e1; flex-shrink:0;
            display:flex; flex-direction:column;
        }
        .admin-side .brand {
            padding: 1rem 1.25rem; border-bottom:1px solid #334155;
            display:flex; align-items:center; gap:.5rem; font-weight:700;
        }
        .admin-side .brand .pill {
            background:#dc2626; color:#fff; font-size:.65rem; padding:2px 8px; border-radius:999px;
            text-transform:uppercase; letter-spacing:.6px;
        }
        .admin-side .nav { flex:1; padding: 1rem .65rem; }
        .admin-side .nav .nav-link {
            color:#cbd5e1; padding:.55rem .85rem; border-radius:.5rem;
            display:flex; align-items:center; gap:.65rem; font-size:.92rem;
        }
        .admin-side .nav .nav-link:hover { background:#334155; color:#fff; }
        .admin-side .nav .nav-link.active { background:#dc2626; color:#fff; }
        .admin-side .foot {
            padding: 1rem 1.25rem; border-top:1px solid #334155; font-size:.85rem;
        }
        .admin-main { flex:1; background:#f1f5f9; color:#0f172a; padding: 1.5rem 2rem; overflow-x:auto; }
        .admin-main h1, .admin-main h2, .admin-main h3, .admin-main h4, .admin-main h5, .admin-main h6 { color:#0f172a; }
        .card { color:#0f172a; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="admin-shell">
    <aside class="admin-side">
        <div class="brand">
            <i class="bi bi-shield-fill-check fs-4"></i>
            <span>TravelERP</span>
            <span class="pill ms-auto">admin</span>
        </div>
        <nav class="nav flex-column">
            <a class="nav-link @Active("Stats")" href="/Admin/Stats"><i class="bi bi-bar-chart-fill"></i>Overview</a>
            <a class="nav-link @Active("Companies")" href="/Admin/Companies"><i class="bi bi-building-fill"></i>Companies</a>
            <a class="nav-link @Active("Plans")" href="/Admin/Plans"><i class="bi bi-tags-fill"></i>Plans</a>
        </nav>
        <div class="foot">
            <div class="small text-muted mb-1">Signed in as</div>
            <div class="fw-semibold small">@User.FindFirst("FullName")?.Value</div>
            <div class="small text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</div>
            <form asp-action="Logout" asp-controller="Auth" method="post" class="mt-2">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-light w-100"><i class="bi bi-box-arrow-right me-1"></i>Sign out</button>
            </form>
        </div>
    </aside>
    <main class="admin-main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <h4 class="mb-3 fw-bold">@ViewData["Title"]</h4>
        @RenderBody()
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
