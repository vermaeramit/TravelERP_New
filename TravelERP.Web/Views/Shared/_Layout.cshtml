<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @User.FindFirst("CompanyName")?.Value</title>

    <!-- AdminLTE 4 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/css/adminlte.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.7/css/dataTables.bootstrap5.min.css" />
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <!-- Custom -->
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

<div class="app-wrapper">

    <!-- TOP NAVBAR -->
    <nav class="app-header navbar navbar-expand bg-body">
        <div class="container-fluid">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                        <i class="bi bi-list fs-4"></i>
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-bell fs-5"></i>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-bs-toggle="offcanvas" data-bs-target="#themePanel" title="Settings">
                        <i class="bi bi-gear fs-5"></i>
                    </a>
                </li>
                <li class="nav-item dropdown user-menu">
                    <a href="#" class="nav-link dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                             style="width:32px;height:32px;font-size:14px">
                            @(User.FindFirst("FullName")?.Value?.Substring(0,1).ToUpper() ?? "U")
                        </div>
                        <span class="d-none d-md-inline">@User.FindFirst("FullName")?.Value</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li class="px-3 py-2">
                            <div class="fw-semibold">@User.FindFirst("FullName")?.Value</div>
                            <div class="text-muted small">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</div>
                            <span class="badge bg-primary">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                        <li><a class="dropdown-item" href="/Account/ChangePassword"><i class="bi bi-lock me-2"></i>Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-action="Logout" asp-controller="Auth" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>

    <!-- SIDEBAR -->
    <aside class="app-sidebar shadow" data-bs-theme="dark">
        <div class="sidebar-brand">
            <a href="/Dashboard" class="brand-link text-decoration-none">
                <i class="bi bi-airplane-fill text-primary fs-4 me-2"></i>
                <span class="brand-text fw-bold fs-5 text-primary">TravelERP</span>
            </a>
        </div>
        <div class="sidebar-wrapper">
            <nav class="mt-2">
                <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu">

                    <li class="nav-header">MAIN</li>
                    <li class="nav-item">
                        <a href="/Dashboard" class="nav-link @NavActive("Dashboard")">
                            <i class="nav-icon bi bi-speedometer2"></i><p>Dashboard</p>
                        </a>
                    </li>

                    <li class="nav-header">OPERATIONS</li>
                    <li class="nav-item">
                        <a href="/Bookings" class="nav-link @NavActive("Bookings")">
                            <i class="nav-icon bi bi-journal-bookmark-fill"></i><p>Bookings</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Customers" class="nav-link @NavActive("Customers")">
                            <i class="nav-icon bi bi-people-fill"></i><p>Customers</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Packages" class="nav-link @NavActive("Packages")">
                            <i class="nav-icon bi bi-map-fill"></i><p>Tour Packages</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Suppliers" class="nav-link @NavActive("Suppliers")">
                            <i class="nav-icon bi bi-building"></i><p>Suppliers</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Visa" class="nav-link @NavActive("Visa")">
                            <i class="nav-icon bi bi-passport"></i><p>Visa &amp; Documents</p>
                        </a>
                    </li>

                    <li class="nav-header">FINANCE</li>
                    <li class="nav-item">
                        <a href="/Finance/Invoices" class="nav-link @NavActive("Finance")">
                            <i class="nav-icon bi bi-receipt"></i><p>Invoices &amp; Payments</p>
                        </a>
                    </li>

                    <li class="nav-header">HR</li>
                    <li class="nav-item @TreeviewOpen("HR")">
                        <a href="#" class="nav-link">
                            <i class="nav-icon bi bi-person-badge"></i>
                            <p>Human Resources <i class="nav-arrow bi bi-chevron-right"></i></p>
                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a href="/HR/Employees" class="nav-link"><i class="nav-icon bi bi-person-lines-fill"></i><p>Employees</p></a>
                            </li>
                            <li class="nav-item">
                                <a href="/HR/Leaves" class="nav-link"><i class="nav-icon bi bi-calendar-check"></i><p>Leave Management</p></a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-header">REPORTS &amp; SETTINGS</li>
                    <li class="nav-item">
                        <a href="/Reports" class="nav-link @NavActive("Reports")">
                            <i class="nav-icon bi bi-bar-chart-fill"></i><p>Reports</p>
                        </a>
                    </li>
                    <li class="nav-item @TreeviewOpen("Company")">
                        <a href="#" class="nav-link">
                            <i class="nav-icon bi bi-gear-fill"></i>
                            <p>Company Setup <i class="nav-arrow bi bi-chevron-right"></i></p>
                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a href="/Company/Settings" class="nav-link"><i class="nav-icon bi bi-sliders"></i><p>Settings</p></a>
                            </li>
                            <li class="nav-item">
                                <a href="/Company/Branches" class="nav-link"><i class="nav-icon bi bi-diagram-3"></i><p>Branches</p></a>
                            </li>
                            <li class="nav-item">
                                <a href="/Company/Users" class="nav-link"><i class="nav-icon bi bi-people"></i><p>Users</p></a>
                            </li>
                        </ul>
                    </li>

                </ul>
            </nav>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="app-main">
        <div class="app-content-header">
            <div class="container-fluid">
                <div class="row mb-2 align-items-center">
                    <div class="col-sm-6">
                        <h3 class="mb-0 fw-bold">@ViewData["Title"]</h3>
                    </div>
                    <div class="col-sm-6">
                        @await Html.PartialAsync("_Breadcrumb")
                    </div>
                </div>
            </div>
        </div>
        <div class="app-content">
            <div class="container-fluid">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="app-footer">
        <strong>TravelERP &copy; @DateTime.Now.Year</strong>
        <span class="float-end d-none d-sm-inline">
            @User.FindFirst("CompanyName")?.Value
        </span>
    </footer>

</div>

<!-- Theme Offcanvas -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="themePanel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title"><i class="bi bi-palette me-2"></i>Theme Settings</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <p class="text-muted small">Color Mode</p>
        <div class="btn-group w-100 mb-3">
            <button class="btn btn-outline-primary" onclick="setTheme('light')">
                <i class="bi bi-sun-fill me-1"></i>Light
            </button>
            <button class="btn btn-outline-secondary" onclick="setTheme('dark')">
                <i class="bi bi-moon-stars-fill me-1"></i>Dark
            </button>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/js/adminlte.min.js"></script>
<script src="https://cdn.datatables.net/2.0.7/js/dataTables.min.js"></script>
<script src="https://cdn.datatables.net/2.0.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="~/js/app.js" asp-append-version="true"></script>

<script>
    function setTheme(t) {
        document.documentElement.setAttribute('data-bs-theme', t);
        localStorage.setItem('erp-theme', t);
    }
    (function () {
        const t = localStorage.getItem('erp-theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', t);
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    string NavActive(string controller) =>
        ViewContext.RouteData.Values["controller"]?.ToString() == controller ? "active" : "";

    string TreeviewOpen(string controller) =>
        ViewContext.RouteData.Values["controller"]?.ToString() == controller ? "menu-open" : "";
}
