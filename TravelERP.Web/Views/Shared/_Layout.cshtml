@inject TravelERP.Core.Interfaces.ICompanyRepository _companyRepo
@inject TravelERP.Core.Interfaces.ITenantContext _tenantCtx
@{
    // One lightweight PK lookup per page so the sidebar logo + title reflect the
    // current company branding without requiring a fresh login.
    var _branding = User.Identity?.IsAuthenticated == true
        ? await _companyRepo.GetByIdAsync(_tenantCtx.CompanyId)
        : null;
    var _brandLogo = _branding?.LogoUrl;
    var _brandName = _branding?.Name ?? User.FindFirst("CompanyName")?.Value ?? "TravelERP";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @_brandName</title>

    <!-- AdminLTE 4 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/css/adminlte.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.7/css/dataTables.bootstrap5.min.css" />
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <!-- Custom -->
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

<div class="app-wrapper">

    <!-- TOP NAVBAR -->
    <nav class="app-header navbar navbar-expand bg-body">
        <div class="container-fluid">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                        <i class="bi bi-list fs-4"></i>
                    </a>
                </li>
                <li class="nav-item d-flex align-items-center">
                    <h5 class="page-title mb-0 fw-bold ms-1">@ViewData["Title"]</h5>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/Today" id="navbarBellLink" title="Today's follow-ups">
                        <span class="position-relative d-inline-flex">
                            <i class="bi bi-bell fs-5"></i>
                            <span id="navbarBellBadge"
                                  class="position-absolute badge rounded-pill bg-danger d-none"
                                  style="font-size: .6rem; padding: 2px 5px; top: -6px; right: -8px; line-height: 1;">0</span>
                        </span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-bs-toggle="offcanvas" data-bs-target="#themePanel" title="Settings">
                        <i class="bi bi-gear fs-5"></i>
                    </a>
                </li>
                <li class="nav-item dropdown user-menu">
                    <a href="#" class="nav-link dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                             style="width:32px;height:32px;font-size:14px">
                            @(User.FindFirst("FullName")?.Value?.Substring(0,1).ToUpper() ?? "U")
                        </div>
                        <span class="d-none d-md-inline">@User.FindFirst("FullName")?.Value</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li class="px-3 py-2">
                            <div class="fw-semibold">@User.FindFirst("FullName")?.Value</div>
                            <div class="text-muted small">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</div>
                            <span class="badge bg-primary">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                        <li><a class="dropdown-item" href="/Account/ChangePassword"><i class="bi bi-lock me-2"></i>Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-action="Logout" asp-controller="Auth" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>

    <!-- SIDEBAR -->
    <aside class="app-sidebar shadow" data-bs-theme="dark">
        <div class="sidebar-brand">
            <a href="/Dashboard" class="brand-link text-decoration-none d-flex align-items-center">
                @if (!string.IsNullOrEmpty(_brandLogo))
                {
                    <img src="@_brandLogo" alt="@_brandName" class="sidebar-logo" />
                    <span class="brand-text fw-bold fs-6 text-light text-truncate">@_brandName</span>
                }
                else
                {
                    <i class="bi bi-airplane-fill text-primary fs-4 me-2"></i>
                    <span class="brand-text fw-bold fs-5 text-primary">@_brandName</span>
                }
            </a>
        </div>
        <div class="sidebar-wrapper">
            <nav class="mt-2">
                <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu">

                    <li class="nav-header">MAIN</li>
                    <li class="nav-item">
                        <a href="/Dashboard" class="nav-link @NavActive("Dashboard")">
                            <i class="nav-icon bi bi-speedometer2"></i><p>Dashboard</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Today" class="nav-link @NavActive("Today")">
                            <i class="nav-icon bi bi-bell"></i>
                            <p>Today
                                <span class="badge bg-danger ms-2 d-none" id="sidebarTodayBadge">0</span>
                            </p>
                        </a>
                    </li>

                    @if (CanSee("Leads") || CanSee("Bookings"))
                    {
                        <li class="nav-header">OPERATIONS</li>
                    }
                    @if (CanSee("Leads"))
                    {
                        <li class="nav-item">
                            <a href="/Leads" class="nav-link @NavActive("Leads")">
                                <i class="nav-icon bi bi-funnel-fill"></i><p>Leads</p>
                            </a>
                        </li>
                    }
                    @if (CanSee("Bookings"))
                    {
                        <li class="nav-item">
                            <a href="/Bookings" class="nav-link @NavActive("Bookings")">
                                <i class="nav-icon bi bi-journal-bookmark-fill"></i><p>Bookings</p>
                            </a>
                        </li>
                    }
                    @* Tour Packages are managed per-lead from /Leads/Details — no top-level link *@


                    @{
                        var anyTravel  = CanSee("Destinations") || CanSee("Hotels") || CanSee("RoomTypes") || CanSee("MealPlans") || CanSee("Sightseeings") || CanSee("Itineraries");
                        var anyCrm     = CanSee("LeadSources") || CanSee("LeadStatuses") || CanSee("ActivityTemplates") || CanSee("VisaTypes") || CanSee("MailTemplates");
                        var anyFinance = CanSee("BankAccounts");
                    }
                    @if (anyTravel || anyCrm || anyFinance)
                    {
                        <li class="nav-header">MASTERS</li>
                    }
                    @if (anyTravel)
                    {
                        <li class="nav-item @TreeviewOpenAny("Destinations","Hotels","RoomTypes","MealPlans","Sightseeings","Itineraries")">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-globe-asia-australia"></i>
                                <p>Travel Masters <i class="nav-arrow bi bi-chevron-right"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                @if (CanSee("Destinations"))
                                {
                                    <li class="nav-item"><a href="/Destinations" class="nav-link @NavActive("Destinations")"><i class="nav-icon bi bi-geo-alt"></i><p>Destinations</p></a></li>
                                }
                                @if (CanSee("Hotels"))
                                {
                                    <li class="nav-item"><a href="/Hotels" class="nav-link @NavActive("Hotels")"><i class="nav-icon bi bi-building"></i><p>Hotels</p></a></li>
                                }
                                @if (CanSee("RoomTypes"))
                                {
                                    <li class="nav-item"><a href="/RoomTypes" class="nav-link @NavActive("RoomTypes")"><i class="nav-icon bi bi-door-closed"></i><p>Room Types</p></a></li>
                                }
                                @if (CanSee("MealPlans"))
                                {
                                    <li class="nav-item"><a href="/MealPlans" class="nav-link @NavActive("MealPlans")"><i class="nav-icon bi bi-egg-fried"></i><p>Meal Plans</p></a></li>
                                }
                                @if (CanSee("Sightseeings"))
                                {
                                    <li class="nav-item"><a href="/Sightseeings" class="nav-link @NavActive("Sightseeings")"><i class="nav-icon bi bi-camera"></i><p>Sightseeing</p></a></li>
                                }
                                @if (CanSee("Itineraries"))
                                {
                                    <li class="nav-item"><a href="/Itineraries" class="nav-link @NavActive("Itineraries")"><i class="nav-icon bi bi-list-ul"></i><p>Itineraries</p></a></li>
                                }
                            </ul>
                        </li>
                    }
                    @if (anyCrm)
                    {
                        <li class="nav-item @TreeviewOpenAny("LeadSources","LeadStatuses","ActivityTemplates","VisaTypes","MailTemplates")">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-collection-fill"></i>
                                <p>CRM Masters <i class="nav-arrow bi bi-chevron-right"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                @if (CanSee("LeadSources"))
                                {
                                    <li class="nav-item"><a href="/LeadSources" class="nav-link @NavActive("LeadSources")"><i class="nav-icon bi bi-megaphone"></i><p>Lead Sources</p></a></li>
                                }
                                @if (CanSee("LeadStatuses"))
                                {
                                    <li class="nav-item"><a href="/LeadStatuses" class="nav-link @NavActive("LeadStatuses")"><i class="nav-icon bi bi-flag"></i><p>Lead Statuses</p></a></li>
                                }
                                @if (CanSee("ActivityTemplates"))
                                {
                                    <li class="nav-item"><a href="/ActivityTemplates" class="nav-link @NavActive("ActivityTemplates")"><i class="nav-icon bi bi-chat-square-text"></i><p>Activity Templates</p></a></li>
                                }
                                @if (CanSee("VisaTypes"))
                                {
                                    <li class="nav-item"><a href="/VisaTypes" class="nav-link @NavActive("VisaTypes")"><i class="nav-icon bi bi-passport"></i><p>Visa Types</p></a></li>
                                }
                                @if (CanSee("MailTemplates"))
                                {
                                    <li class="nav-item"><a href="/MailTemplates" class="nav-link @NavActive("MailTemplates")"><i class="nav-icon bi bi-envelope-paper"></i><p>Mail Templates</p></a></li>
                                }
                            </ul>
                        </li>
                    }
                    @if (anyFinance)
                    {
                        <li class="nav-item @TreeviewOpenAny("BankAccounts")">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-cash-stack"></i>
                                <p>Finance Masters <i class="nav-arrow bi bi-chevron-right"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                @if (CanSee("BankAccounts"))
                                {
                                    <li class="nav-item"><a href="/BankAccounts" class="nav-link @NavActive("BankAccounts")"><i class="nav-icon bi bi-bank"></i><p>Bank Accounts</p></a></li>
                                }
                            </ul>
                        </li>
                    }

                    @{ var isSuperAdmin = User.HasClaim("IsSuperAdmin", "true"); }
                    @if (CanSee("Reports") || CanSee("Roles") || isSuperAdmin)
                    {
                        <li class="nav-header">REPORTS &amp; SETTINGS</li>
                    }
                    @if (CanSee("Reports"))
                    {
                        <li class="nav-item">
                            <a href="/Reports" class="nav-link @NavActive("Reports")">
                                <i class="nav-icon bi bi-bar-chart-fill"></i><p>Reports</p>
                            </a>
                        </li>
                    }
                    @if (CanSee("Roles"))
                    {
                        <li class="nav-item">
                            <a href="/Roles" class="nav-link @NavActive("Roles")">
                                <i class="nav-icon bi bi-shield-lock-fill"></i><p>Roles &amp; Permissions</p>
                            </a>
                        </li>
                    }
                    @if (isSuperAdmin)
                    {
                        <li class="nav-item @TreeviewOpen("Company")">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-gear-fill"></i>
                                <p>Company Setup <i class="nav-arrow bi bi-chevron-right"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="/Company/Settings" class="nav-link"><i class="nav-icon bi bi-sliders"></i><p>Settings</p></a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Company/Users" class="nav-link"><i class="nav-icon bi bi-people"></i><p>Users</p></a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Company/QuoteBranding" class="nav-link"><i class="nav-icon bi bi-stars"></i><p>Quote Branding</p></a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Company/VoucherDefaults" class="nav-link"><i class="nav-icon bi bi-building-check"></i><p>Voucher Defaults</p></a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Company/EmailSettings" class="nav-link"><i class="nav-icon bi bi-envelope-paper"></i><p>Email Settings</p></a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Company/NumberSeries" class="nav-link"><i class="nav-icon bi bi-hash"></i><p>Number Series</p></a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Company/ApiKeys" class="nav-link"><i class="nav-icon bi bi-key"></i><p>API Keys</p></a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Company/ApiDocs" class="nav-link"><i class="nav-icon bi bi-code-slash"></i><p>API Docs</p></a>
                                </li>
                            </ul>
                        </li>
                    }

                </ul>
            </nav>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="app-main">
        <div class="app-content">
            <div class="container-fluid">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="app-footer">
        <strong>TravelERP &copy; @DateTime.Now.Year</strong>
        <span class="float-end d-none d-sm-inline">
            @User.FindFirst("CompanyName")?.Value
        </span>
    </footer>

</div>

<!-- Theme Offcanvas -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="themePanel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title"><i class="bi bi-palette me-2"></i>Theme Settings</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <p class="text-muted small">Color Mode</p>
        <div class="btn-group w-100 mb-3">
            <button class="btn btn-outline-primary" onclick="setTheme('light')">
                <i class="bi bi-sun-fill me-1"></i>Light
            </button>
            <button class="btn btn-outline-secondary" onclick="setTheme('dark')">
                <i class="bi bi-moon-stars-fill me-1"></i>Dark
            </button>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/js/adminlte.min.js"></script>
<script src="https://cdn.datatables.net/2.0.7/js/dataTables.min.js"></script>
<script src="https://cdn.datatables.net/2.0.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="~/js/app.js" asp-append-version="true"></script>

<script>
    function setTheme(t) {
        document.documentElement.setAttribute('data-bs-theme', t);
        localStorage.setItem('erp-theme', t);
    }
    (function () {
        const t = localStorage.getItem('erp-theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', t);
    })();

    // Today-panel badges (navbar bell + sidebar). Refreshed on every page load.
    (async function () {
        try {
            const r = await fetch('/Today/Counts', { credentials: 'same-origin' });
            if (!r.ok) return;
            const j = await r.json();
            const bell = document.getElementById('navbarBellBadge');
            const side = document.getElementById('sidebarTodayBadge');
            const n = j.actionable || 0;
            if (n > 0) {
                if (bell) { bell.textContent = n; bell.classList.remove('d-none'); }
                if (side) { side.textContent = n; side.classList.remove('d-none'); }
            }
        } catch { /* unauthenticated or first-load — ignore */ }
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    string NavActive(string controller) =>
        ViewContext.RouteData.Values["controller"]?.ToString() == controller ? "active" : "";

    string TreeviewOpen(string controller) =>
        ViewContext.RouteData.Values["controller"]?.ToString() == controller ? "menu-open" : "";

    string TreeviewOpenAny(params string[] controllers) =>
        controllers.Contains(ViewContext.RouteData.Values["controller"]?.ToString() ?? "") ? "menu-open" : "";

    bool CanSee(string module) =>
        User.HasClaim("IsSuperAdmin", "true") ||
        User.HasClaim("Perm", $"{module}.View");
}
