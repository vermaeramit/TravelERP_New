@{
    Layout = "_Layout";
    ViewData["Title"] = "Error";
    var requestId = Activity.Current?.Id ?? ViewContext.HttpContext?.TraceIdentifier;
}
@using System.Diagnostics

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:4rem"></i>
    <h2 class="mt-3 fw-bold">Oops! Something went wrong.</h2>
    <p class="text-muted">An unexpected error occurred. Please try again or contact support.</p>
    @if (!string.IsNullOrEmpty(requestId))
    {
        <p class="small text-muted">Request ID: <code>@requestId</code></p>
    }
    <a href="/Dashboard" class="btn btn-primary mt-2"><i class="bi bi-house me-1"></i>Back to Dashboard</a>
</div>
