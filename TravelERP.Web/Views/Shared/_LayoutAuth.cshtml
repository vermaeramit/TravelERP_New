<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - TravelERP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #f4f6fb;
        }

        /* ── Left panel ── */
        .auth-left {
            width: 440px;
            min-height: 100vh;
            flex-shrink: 0;
            background: linear-gradient(160deg, #0f1f4b 0%, #1a3a8f 55%, #1565c0 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 3rem 2.5rem;
            position: relative;
            overflow: hidden;
        }
        .auth-left::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 320px; height: 320px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
        }
        .auth-left::after {
            content: '';
            position: absolute;
            bottom: -100px; left: -60px;
            width: 380px; height: 380px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
        }

        .auth-brand {
            position: relative;
            z-index: 1;
        }
        .auth-brand .brand-icon {
            width: 52px; height: 52px;
            background: rgba(255,255,255,0.15);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.6rem;
            color: #fff;
            margin-bottom: 1rem;
            backdrop-filter: blur(6px);
        }
        .auth-brand h1 {
            color: #fff;
            font-size: 1.75rem;
            font-weight: 800;
            margin: 0 0 0.25rem;
            letter-spacing: -0.5px;
        }
        .auth-brand p {
            color: rgba(255,255,255,0.6);
            font-size: 0.9rem;
            margin: 0;
        }

        .auth-features {
            position: relative;
            z-index: 1;
        }
        .auth-features h3 {
            color: #fff;
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            line-height: 1.3;
        }
        .feature-item {
            display: flex;
            align-items: flex-start;
            gap: 0.9rem;
            margin-bottom: 1.1rem;
        }
        .feature-icon {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: rgba(255,255,255,0.12);
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
            color: #7eb8ff;
            flex-shrink: 0;
            backdrop-filter: blur(4px);
        }
        .feature-text strong {
            display: block;
            color: #fff;
            font-size: 0.88rem;
            font-weight: 600;
        }
        .feature-text span {
            color: rgba(255,255,255,0.5);
            font-size: 0.78rem;
        }

        .auth-footer {
            position: relative;
            z-index: 1;
            color: rgba(255,255,255,0.35);
            font-size: 0.78rem;
        }

        /* ── Right panel ── */
        .auth-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            overflow-y: auto;
        }
        .auth-form-wrap {
            width: 100%;
            max-width: 440px;
        }

        /* ── Form elements ── */
        .auth-form-wrap .form-control,
        .auth-form-wrap .form-select {
            border-radius: 10px;
            border: 1.5px solid #e2e8f0;
            padding: 0.6rem 0.9rem;
            font-size: 0.9rem;
            background: #fff;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .auth-form-wrap .form-control:focus,
        .auth-form-wrap .form-select:focus {
            border-color: #1a3a8f;
            box-shadow: 0 0 0 3px rgba(26,58,143,0.1);
        }
        .auth-form-wrap .input-group-text {
            border-radius: 10px 0 0 10px;
            border: 1.5px solid #e2e8f0;
            border-right: none;
            background: #f8fafc;
            color: #94a3b8;
        }
        .auth-form-wrap .input-group .form-control {
            border-radius: 0 10px 10px 0;
        }
        .auth-form-wrap .input-group .btn {
            border-radius: 0 10px 10px 0;
            border: 1.5px solid #e2e8f0;
            border-left: none;
        }
        .auth-form-wrap label {
            font-size: 0.82rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.35rem;
        }
        .form-text {
            font-size: 0.76rem;
            color: #94a3b8;
        }

        .btn-auth-primary {
            background: linear-gradient(135deg, #1a3a8f, #1565c0);
            border: none;
            border-radius: 10px;
            padding: 0.7rem 1rem;
            font-weight: 600;
            font-size: 0.95rem;
            color: #fff;
            transition: opacity 0.15s, transform 0.1s;
        }
        .btn-auth-primary:hover {
            opacity: 0.92;
            color: #fff;
            transform: translateY(-1px);
        }

        .section-divider {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 1.25rem 0;
            color: #cbd5e1;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .section-divider::before,
        .section-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

        /* ── Responsive ── */
        @@media (max-width: 768px) {
            .auth-left { display: none; }
            body { background: #fff; }
            .auth-right { padding: 1.5rem; }
        }
    </style>
</head>
<body>

    <!-- Left branding panel -->
    <div class="auth-left">
        <div class="auth-brand">
            <div class="brand-icon"><i class="bi bi-airplane-fill"></i></div>
            <h1>TravelERP</h1>
            <p>Enterprise Travel Management Platform</p>
        </div>

        <div class="auth-features">
            <h3>Everything your travel business needs in one place</h3>
            <div class="feature-item">
                <div class="feature-icon"><i class="bi bi-journal-bookmark-fill"></i></div>
                <div class="feature-text">
                    <strong>Smart Booking Management</strong>
                    <span>Track bookings, payments & invoices effortlessly</span>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon"><i class="bi bi-people-fill"></i></div>
                <div class="feature-text">
                    <strong>Customer 360°</strong>
                    <span>Full customer profiles, loyalty points & history</span>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon"><i class="bi bi-passport"></i></div>
                <div class="feature-text">
                    <strong>Visa & Document Tracking</strong>
                    <span>Never miss a visa deadline again</span>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                <div class="feature-text">
                    <strong>Real-time Reports</strong>
                    <span>Revenue, bookings & performance at a glance</span>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
                <div class="feature-text">
                    <strong>Multi-tenant & Secure</strong>
                    <span>Each company gets its own isolated database</span>
                </div>
            </div>
        </div>

        <div class="auth-footer">
            &copy; @DateTime.Now.Year TravelERP &nbsp;·&nbsp; All rights reserved
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-right">
        <div class="auth-form-wrap">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
