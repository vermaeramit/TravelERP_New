@model TravelERP.Web.Controllers.AccountController.ChangePasswordVm
@{ ViewData["Title"] = "Change Password"; }

<form asp-action="ChangePassword" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <div class="col-lg-7">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent border-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-lock text-primary me-2"></i>Change Password</h6>
                <small class="text-muted">Your new password takes effect immediately — you'll stay signed in on this device.</small>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="CurrentPassword" class="form-label small fw-semibold">Current Password <span class="text-danger">*</span></label>
                        <input asp-for="CurrentPassword" type="password" class="form-control" autocomplete="current-password" required />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NewPassword" class="form-label small fw-semibold">New Password <span class="text-danger">*</span></label>
                        <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" minlength="6" required />
                        <small class="text-muted">Minimum 6 characters.</small>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label small fw-semibold">Confirm New Password <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" minlength="6" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a href="/Account/Profile" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-key me-1"></i>Update Password
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
