@model TravelERP.Web.Controllers.AccountController.ProfileVm
@{ ViewData["Title"] = "My Profile"; }

@section Styles {
    <style>
        .img-preview     { width: 120px; height: 120px; object-fit: cover; border-radius: 50%;
                           border: 1px solid var(--bs-border-color); }
        .img-placeholder { width: 120px; height: 120px; border: 2px dashed var(--bs-border-color);
                           border-radius: 50%; display: flex; align-items: center; justify-content: center;
                           color: var(--bs-secondary-color); }
    </style>
}

<form asp-action="Profile" method="post" enctype="multipart/form-data" class="row g-3">
    @Html.AntiForgeryToken()

    <div class="col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent border-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-person-vcard text-primary me-2"></i>My Profile</h6>
                <small class="text-muted">Update your own contact details and photo. Ask an admin to change your email or role.</small>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-9">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label small fw-semibold">Full Name <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" required />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Email</label>
                                <input value="@Model.Email" class="form-control" disabled />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Mobile" class="form-label small fw-semibold">Mobile</label>
                                <input asp-for="Mobile" class="form-control" placeholder="+91 …" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DateOfBirth" class="form-label small fw-semibold">Date of Birth</label>
                                <input asp-for="DateOfBirth" type="date" class="form-control"
                                       value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" />
                            </div>

                            <div class="col-12">
                                <label asp-for="ReplyEmail" class="form-label small fw-semibold">Reply-To Email</label>
                                <input asp-for="ReplyEmail" type="email" class="form-control"
                                       placeholder="Used when travelers reply to emails you send" />
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="form-label small fw-semibold d-block">Photo <span class="text-muted">(120×120)</span></label>
                        <div class="d-flex flex-column align-items-center gap-2">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img class="img-preview photo-preview" src="@Model.ImageUrl" />
                                <div class="img-placeholder photo-placeholder d-none"><i class="bi bi-person fs-2"></i></div>
                            }
                            else
                            {
                                <div class="img-placeholder photo-placeholder"><i class="bi bi-person fs-2"></i></div>
                                <img class="img-preview photo-preview d-none" />
                            }
                            <input type="file" name="photo" accept="image/*" class="form-control form-control-sm photo-input" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a href="/Account/ChangePassword" class="btn btn-outline-secondary">
                <i class="bi bi-lock me-1"></i>Change Password
            </a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-1"></i>Save Changes
            </button>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm bg-light border-0">
            <div class="card-body small">
                <h6 class="fw-bold mb-2"><i class="bi bi-info-circle text-primary me-2"></i>About this page</h6>
                <ul class="ps-3 mb-0">
                    <li>You can change your own profile details here.</li>
                    <li>Email and role changes require a company admin.</li>
                    <li>For security, change your password regularly using the button on the left.</li>
                </ul>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const photoInput       = document.querySelector('.photo-input');
        const photoPreview     = document.querySelector('.photo-preview');
        const photoPlaceholder = document.querySelector('.photo-placeholder');
        photoInput?.addEventListener('change', e => {
            const f = e.target.files?.[0]; if (!f) return;
            photoPreview.src = URL.createObjectURL(f);
            photoPreview.classList.remove('d-none');
            photoPlaceholder.classList.add('d-none');
        });
    </script>
}
