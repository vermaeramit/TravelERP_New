@model TravelERP.Shared.DTOs.LoginDto
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Sign In";
}

<div class="mb-4">
    <h2 class="fw-800 mb-1" style="font-weight:800;font-size:1.75rem;color:#0f1f4b;letter-spacing:-0.5px">Welcome back</h2>
    <p class="text-muted mb-0" style="font-size:0.92rem">Sign in to your TravelERP account</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 rounded-3 small py-2 mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
    </div>
}

<form asp-action="Login" asp-controller="Auth" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small py-2 mb-3"></div>

    <!-- Company Code -->
    <div class="mb-3">
        <label asp-for="CompanyCode" class="form-label">Company Code</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-building"></i></span>
            <input asp-for="CompanyCode" class="form-control" placeholder="your-company-code"
                   autocomplete="organization" autofocus spellcheck="false" />
        </div>
        <span asp-validation-for="CompanyCode" class="text-danger" style="font-size:0.78rem"></span>
        <div class="form-text">The unique code you set during company registration</div>
    </div>

    <!-- Email -->
    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email Address</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Email" class="form-control" placeholder="you@company.com" autocomplete="email" />
        </div>
        <span asp-validation-for="Email" class="text-danger" style="font-size:0.78rem"></span>
    </div>

    <!-- Password -->
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <label asp-for="Password" class="form-label mb-0">Password</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input asp-for="Password" class="form-control" placeholder="••••••••"
                   autocomplete="current-password" id="pwdInput" />
            <button class="btn btn-outline-secondary" type="button" onclick="togglePwd()" tabindex="-1">
                <i class="bi bi-eye" id="pwdIcon"></i>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger" style="font-size:0.78rem"></span>
    </div>

    <!-- Remember me -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="form-check mb-0">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label" style="font-size:0.85rem">Keep me signed in</label>
        </div>
    </div>

    <button type="submit" class="btn btn-auth-primary w-100">
        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
    </button>
</form>

<div class="text-center mt-4" style="font-size:0.87rem;color:#64748b">
    Don't have an account?
    <a href="/register" class="fw-semibold text-decoration-none" style="color:#1a3a8f">Register your company</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd() {
            const i = document.getElementById('pwdInput');
            const icon = document.getElementById('pwdIcon');
            if (i.type === 'password') { i.type = 'text'; icon.className = 'bi bi-eye-slash'; }
            else { i.type = 'password'; icon.className = 'bi bi-eye'; }
        }

        // Pre-fill company code if passed from registration success page
        (function () {
            const params = new URLSearchParams(window.location.search);
            const code = params.get('code');
            if (code) {
                const field = document.getElementById('CompanyCode');
                if (field && !field.value) field.value = code;
            }
        })();
    </script>
}
