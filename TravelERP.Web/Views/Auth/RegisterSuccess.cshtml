@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Registration Successful";

    var companyName = TempData["Reg_CompanyName"]?.ToString() ?? "";
    var companyCode = TempData["Reg_CompanyCode"]?.ToString() ?? "";
    var adminEmail  = TempData["Reg_AdminEmail"]?.ToString() ?? "";
    var adminName   = TempData["Reg_AdminName"]?.ToString() ?? "";
    var provErr     = TempData["ProvisionError"]?.ToString();
}

<!-- Success hero -->
<div class="text-center mb-4">
    <div class="success-circle mx-auto mb-3">
        <i class="bi bi-check-lg"></i>
    </div>
    <h2 class="fw-800 mb-1" style="font-weight:800;font-size:1.75rem;color:#0f1f4b;letter-spacing:-0.5px">
        You're all set, @adminName!
    </h2>
    <p class="text-muted mb-0" style="font-size:0.92rem">
        <strong>@companyName</strong> has been registered. Here are your login details.
    </p>
</div>

@if (!string.IsNullOrEmpty(provErr))
{
    <div class="alert alert-warning border-0 rounded-3 small py-2 mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@provErr
    </div>
}

<!-- Details card -->
<div class="details-card mb-4">

    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-building me-2"></i>Company Name</span>
        <span class="detail-value">@companyName</span>
    </div>

    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-tag me-2"></i>Company Code</span>
        <span class="detail-value">
            <code class="code-chip" id="copyCode">@companyCode</code>
            <button class="btn-copy" onclick="copyCode()" title="Copy">
                <i class="bi bi-clipboard" id="copyIcon"></i>
            </button>
        </span>
    </div>

    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-envelope me-2"></i>Admin Email</span>
        <span class="detail-value">@adminEmail</span>
    </div>

    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-lock me-2"></i>Password</span>
        <span class="detail-value">
            <span id="pwdMask">••••••••••</span>
        </span>
    </div>

    <div class="detail-row" style="border-bottom:none;padding-bottom:0">
        <span class="detail-label"><i class="bi bi-clock me-2"></i>Free Trial</span>
        <span class="detail-value">
            <span class="badge-trial">30 days remaining</span>
        </span>
    </div>

</div>

<!-- Important note -->
<div class="alert alert-info border-0 rounded-3 small py-2 mb-4" style="background:#eff6ff;color:#1e40af;">
    <i class="bi bi-info-circle-fill me-2"></i>
    Save your <strong>Company Code</strong> — you'll need it every time you sign in.
</div>

<!-- CTA -->
<a href="/login?code=@companyCode" class="btn btn-auth-primary w-100 mb-3">
    <i class="bi bi-box-arrow-in-right me-2"></i>Go to Sign In
</a>

<div class="text-center" style="font-size:0.82rem;color:#94a3b8">
    Need help? <a href="mailto:support@travelcrm.io" class="text-decoration-none" style="color:#1a3a8f">Contact support</a>
</div>

@section Scripts {
    <script>
        function copyCode() {
            const code = document.getElementById('copyCode').innerText;
            navigator.clipboard.writeText(code).then(() => {
                const icon = document.getElementById('copyIcon');
                icon.className = 'bi bi-clipboard-check';
                setTimeout(() => icon.className = 'bi bi-clipboard', 2000);
            });
        }

        // Pre-fill company code on login page if navigated there
        const loginLink = document.querySelector('a[href^="/login"]');
    </script>
}

<style>
    .success-circle {
        width: 72px; height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem;
        color: #fff;
        box-shadow: 0 4px 20px rgba(34,197,94,0.35);
    }

    .details-card {
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }

    .detail-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.85rem 1.2rem;
        border-bottom: 1px solid #f1f5f9;
        gap: 1rem;
    }

    .detail-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #64748b;
        white-space: nowrap;
    }

    .detail-value {
        font-size: 0.88rem;
        color: #0f172a;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        text-align: right;
    }

    .code-chip {
        background: #f0f4ff;
        color: #1a3a8f;
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        font-size: 0.88rem;
        font-family: 'Courier New', monospace;
        letter-spacing: 0.3px;
    }

    .btn-copy {
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        padding: 0 0.2rem;
        font-size: 0.9rem;
        transition: color 0.15s;
    }
    .btn-copy:hover { color: #1a3a8f; }

    .badge-trial {
        background: #fef3c7;
        color: #92400e;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.25rem 0.6rem;
        border-radius: 20px;
    }
</style>
