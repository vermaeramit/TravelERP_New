@model IEnumerable<TravelERP.Core.Entities.Master.SubscriptionPlan>
@{
    Layout = "_LayoutPlans";
    ViewData["Title"] = "Pricing Plans";

    var plans = Model?.ToList() ?? new();

    string FmtMoney(decimal d) => d.ToString("N0");

    IEnumerable<(string Text, bool Disabled)> ParseFeatures(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) yield break;
        foreach (var line in raw.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            var trimmed = line.Trim();
            if (trimmed.Length == 0) continue;
            if (trimmed.StartsWith("-")) yield return (trimmed.TrimStart('-').Trim(), true);
            else                          yield return (trimmed, false);
        }
    }
}

<div class="plans-hero text-center mb-5">
    <div class="badge-pill mb-3">Simple, transparent pricing</div>
    <h1 class="plans-title">Choose the plan that fits<br>your travel business</h1>
    <p class="plans-subtitle">Start free for 30 days — no credit card required. Cancel anytime.</p>

    @if (plans.Any(p => p.YearlyPrice > 0 && p.MonthlyPrice > 0))
    {
        <div class="billing-toggle mt-4">
            <span class="toggle-label" id="lblMonthly">Monthly</span>
            <label class="toggle-switch">
                <input type="checkbox" id="billingToggle" onchange="switchBilling(this)">
                <span class="slider"></span>
            </label>
            <span class="toggle-label" id="lblYearly">Yearly <span class="save-badge">Save</span></span>
        </div>
    }
</div>

@if (!plans.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-tags fs-1 d-block mb-2 opacity-50"></i>
        <p>No plans are configured yet.</p>
    </div>
}
else
{
    <div class="plans-grid">
        @foreach (var p in plans)
        {
            var iconClass = string.IsNullOrWhiteSpace(p.IconClass) ? "bi-tag" : p.IconClass;
            var iconColor = string.IsNullOrWhiteSpace(p.IconColor) ? "#3b82f6" : p.IconColor;
            var ctaLabel  = string.IsNullOrWhiteSpace(p.CtaLabel)  ? "Start Free Trial" : p.CtaLabel;
            var ctaUrl    = string.IsNullOrWhiteSpace(p.CtaUrl)    ? "/register"        : p.CtaUrl;
            var yearlyMonthly = p.YearlyPrice > 0 ? Math.Round(p.YearlyPrice / 12m, 0) : p.MonthlyPrice;
            <div class="plan-card @(p.IsFeatured ? "plan-featured" : "")">
                @if (p.IsFeatured)
                {
                    <div class="popular-badge">Most Popular</div>
                }
                <div class="plan-header">
                    <div class="plan-icon" style="background: @(p.IsFeatured ? "rgba(255,255,255,0.15)" : iconColor + "22"); color: @(p.IsFeatured ? "#fff" : iconColor)">
                        <i class="bi @iconClass"></i>
                    </div>
                    <h3 class="plan-name">@p.Name</h3>
                    @if (!string.IsNullOrWhiteSpace(p.Tagline))
                    {
                        <p class="plan-tagline">@p.Tagline</p>
                    }
                </div>
                <div class="plan-price">
                    <span class="currency">₹</span>
                    <span class="amount"
                          data-monthly="@FmtMoney(p.MonthlyPrice)"
                          data-yearly="@FmtMoney(yearlyMonthly)">@FmtMoney(p.MonthlyPrice)</span>
                    <span class="period">/month</span>
                </div>
                <div class="plan-billing-note"
                     data-monthly="Billed monthly"
                     data-yearly="@(p.YearlyPrice > 0 ? $"Billed ₹{FmtMoney(p.YearlyPrice)}/year" : "Billed monthly")">
                    Billed monthly
                </div>
                <ul class="plan-features">
                    @foreach (var (text, disabled) in ParseFeatures(p.Features))
                    {
                        <li class="@(disabled ? "disabled" : "")">
                            <i class="bi @(disabled ? "bi-x-circle" : "bi-check-circle-fill")"></i>
                            @text
                        </li>
                    }
                </ul>
                <a href="@ctaUrl" class="btn-plan @(p.IsFeatured ? "btn-plan-primary" : "btn-plan-outline")">@ctaLabel</a>
            </div>
        }
    </div>
}

<!-- FAQ / trust strip -->
<div class="trust-strip mt-5">
    <div class="trust-item"><i class="bi bi-shield-check"></i> No credit card to start</div>
    <div class="trust-item"><i class="bi bi-arrow-counterclockwise"></i> Cancel anytime</div>
    <div class="trust-item"><i class="bi bi-lock"></i> Data stays yours</div>
    <div class="trust-item"><i class="bi bi-headset"></i> 24/7 support on paid plans</div>
</div>

<div class="text-center mt-4" style="font-size:0.85rem;color:#64748b">
    Already have an account? <a href="/login" class="fw-semibold text-decoration-none" style="color:#1a3a8f">Sign in</a>
</div>

@section Scripts {
    <script>
        let yearly = false;
        function switchBilling(cb) {
            yearly = cb.checked;
            document.querySelectorAll('.amount').forEach(el => {
                el.textContent = yearly ? el.dataset.yearly : el.dataset.monthly;
            });
            document.querySelectorAll('.plan-billing-note').forEach(el => {
                el.textContent = yearly ? el.dataset.yearly : el.dataset.monthly;
            });
            const lblM = document.getElementById('lblMonthly');
            const lblY = document.getElementById('lblYearly');
            if (lblM && lblY) {
                lblM.style.fontWeight = yearly ? '400' : '700';
                lblY.style.fontWeight = yearly ? '700' : '400';
            }
        }
    </script>
}
