@model IEnumerable<TravelERP.Core.Entities.Tenant.Itinerary>
@inject TravelERP.Core.Interfaces.ITenantContext Tenant
@{ ViewData["Title"] = "Itineraries"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0 small">Manage itinerary templates per destination.</p>
    @if (Tenant.CanAdd(TravelERP.Core.Constants.AppModules.Itineraries))
    {
        <a href="/Itineraries/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add Itinerary
        </a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-list-ul fs-1 d-block mb-2"></i>
                <p class="mb-0">No itineraries yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Destination</th>
                            <th style="width:160px">Created</th>
                            <th style="width:160px" class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in Model)
                        {
                            <tr>
                                <td class="fw-semibold ps-3">@i.Title</td>
                                <td><span class="badge bg-light text-dark">@i.DestinationName</span></td>
                                <td class="small text-muted">@i.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                <td class="text-end pe-3">
                                    @if (Tenant.CanEdit(TravelERP.Core.Constants.AppModules.Itineraries))
                                    {
                                        <a href="/Itineraries/Edit/@i.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    @if (Tenant.CanDelete(TravelERP.Core.Constants.AppModules.Itineraries))
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline"
                                              onsubmit="return confirm('Deactivate this itinerary?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@i.Id" />
                                            <button class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
