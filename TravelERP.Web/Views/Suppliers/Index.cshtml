@model IEnumerable<TravelERP.Core.Entities.Tenant.Supplier>
@{
    ViewData["Title"] = "Suppliers";
}
<div class="card shadow-sm">
    <div class="card-header bg-transparent border-0 section-header">
        <h5><i class="bi bi-building text-primary me-2"></i>Suppliers</h5>
        <a href="/Suppliers/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Add Supplier
        </a>
    </div>
    <div class="card-body">
        <table class="table table-hover dt-table">
            <thead>
                <tr>
                    <th>Code</th><th>Name</th><th>Category</th><th>Contact</th>
                    <th>Email</th><th>Phone</th><th>Country</th><th>Status</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td><span class="badge bg-light text-dark border">@s.SupplierCode</span></td>
                        <td class="fw-semibold">@s.Name</td>
                        <td>@s.Category</td>
                        <td>@s.ContactPerson</td>
                        <td>@s.Email</td>
                        <td>@s.Phone</td>
                        <td>@s.Country</td>
                        <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <a href="/Suppliers/Edit/@s.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="/Suppliers/Delete/@s.Id" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger btn-confirm-delete"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
