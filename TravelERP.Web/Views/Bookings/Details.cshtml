@using TravelERP.Core.Entities.Tenant
@model Booking
@inject TravelERP.Core.Interfaces.ITenantContext Tenant
@{
    ViewData["Title"] = $"Booking {Model.BookingNumber}";
    var canEdit = Tenant.CanEdit(TravelERP.Core.Constants.AppModules.Bookings);

    string StatusBadge(string s) => s?.ToLowerInvariant() switch
    {
        "confirmed" => "bg-success",
        "completed" => "bg-primary",
        "cancelled" => "bg-danger",
        _           => "bg-secondary"
    };
    string PayBadge(string s) => s?.ToLowerInvariant() switch
    {
        "received" => "bg-success-subtle text-success",
        "refunded" => "bg-warning-subtle text-warning",
        _          => "bg-light text-dark"
    };
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
    <style>
        .email-quill-host { background: #fff; border-radius: 0 0 .375rem .375rem; }
        .email-quill-host .ql-toolbar { border-radius: .375rem .375rem 0 0; }
        .email-quill-host .ql-container { min-height: 180px; max-height: 320px; overflow-y: auto; font-size: .9rem; }
    </style>
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-1">@Model.CustomerName</h4>
        <div class="text-muted small">
            <span class="font-monospace">@Model.BookingNumber</span>
            <span class="ms-3">Invoice <span class="font-monospace">@Model.InvoiceNumber</span></span>
            @if (!string.IsNullOrEmpty(Model.LeadNumber))
            {
                <span class="ms-3">Lead <span class="font-monospace">@Model.LeadNumber</span></span>
            }
            @if (!string.IsNullOrEmpty(Model.PackageNumber))
            {
                <span class="ms-3">Trip ID <span class="font-monospace">@Model.PackageNumber</span></span>
            }
            <span class="badge @StatusBadge(Model.Status) ms-2">@Model.Status</span>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (Model.LeadId.HasValue)
        {
            <a href="/Leads/Details/@Model.LeadId" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-funnel me-1"></i>View Lead
            </a>
        }
        @if (Model.PackageId.HasValue)
        {
            <a href="/Packages/Details/@Model.PackageId" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-suitcase me-1"></i>View Package
            </a>
        }
        <a href="/Bookings/@Model.Id/invoice" target="_blank" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-receipt me-1"></i>Invoice
        </a>
        <a href="/Bookings/@Model.Id/voucher" target="_blank" class="btn btn-outline-warning btn-sm">
            <i class="bi bi-building me-1"></i>Voucher
        </a>
        <button type="button" class="btn btn-info btn-sm text-white"
                data-bs-toggle="modal" data-bs-target="#bookingEmailModal">
            <i class="bi bi-envelope-paper-fill me-1"></i>Email Invoice
        </button>
        <button type="button" class="btn btn-warning btn-sm"
                data-bs-toggle="modal" data-bs-target="#bookingVoucherEmailModal">
            <i class="bi bi-envelope-check-fill me-1"></i>Email Voucher
        </button>
        @if (canEdit)
        {
            <a href="/Bookings/Edit/@Model.Id" class="btn btn-warning btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
    </div>
</div>

@{
    var invSubject = $"Invoice {Model.InvoiceNumber} — {Model.CustomerName}";
    var invBody    = $"<p>Dear {Model.CustomerName},</p>" +
                     $"<p>Please find your invoice <strong>{Model.InvoiceNumber}</strong> attached for booking <strong>{Model.BookingNumber}</strong>.</p>" +
                     $"<p>Total: <strong>{Model.Currency} {Model.TotalAmount:N2}</strong>" +
                     (Model.BalanceAmount > 0 ? $" — Balance due: <strong>{Model.Currency} {Model.BalanceAmount:N2}</strong>" : " — fully paid") +
                     "</p><p>Please feel free to reach out if you have any questions.</p>";
}

<!-- Send Invoice by Email -->
<div class="modal fade" id="bookingEmailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form id="bookingEmailForm">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-envelope-paper-fill text-primary me-2"></i>Email Invoice
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">To <span class="text-danger">*</span></label>
                            <input type="email" name="To" class="form-control form-control-sm"
                                   value="@Model.CustomerEmail" required multiple />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Cc</label>
                            <input type="text" name="Cc" class="form-control form-control-sm"
                                   placeholder="optional, comma-separated" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Subject <span class="text-danger">*</span></label>
                            <input type="text" name="Subject" class="form-control form-control-sm" value="@invSubject" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Body</label>
                            <div class="email-quill-host"><div id="invoiceBodyEditor"></div></div>
                            <input type="hidden" name="Body" id="invoiceBodyHidden" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="AttachPdf" id="bkAttachPdf" value="true" checked />
                                <input type="hidden" name="AttachPdf" value="false" />
                                <label class="form-check-label small" for="bkAttachPdf">
                                    <i class="bi bi-file-earmark-pdf me-1 text-danger"></i>
                                    Attach <strong>Invoice-@(Model.InvoiceNumber).pdf</strong>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="bookingEmailResult" class="mt-3 small"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4" id="bookingEmailSendBtn">
                        <i class="bi bi-send me-1"></i>Send
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@{
    var vchSubject = $"Hotel Voucher {Model.BookingNumber} — {Model.CustomerName}";
    var vchBody    = $"<p>Dear {Model.CustomerName},</p>" +
                     $"<p>Please find your Hotel Voucher for booking <strong>{Model.BookingNumber}</strong> attached.</p>" +
                     $"<p>Travel: {(Model.StartDate?.ToString("dd MMM yyyy") ?? "TBD")}" +
                     (Model.Days.HasValue ? $" · {Model.Days} days" : "") +
                     (string.IsNullOrEmpty(Model.DestinationName) ? "" : $" · {Model.DestinationName}") +
                     "</p>" +
                     "<p>Please present an electronic or paper copy of the voucher upon hotel check-in.</p>" +
                     "<p>Have a great trip!</p>";
}

<!-- Send Voucher by Email -->
<div class="modal fade" id="bookingVoucherEmailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form id="bookingVoucherEmailForm">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-envelope-check-fill text-warning me-2"></i>Email Hotel Voucher
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">To <span class="text-danger">*</span></label>
                            <input type="email" name="To" class="form-control form-control-sm"
                                   value="@Model.CustomerEmail" required multiple />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Cc</label>
                            <input type="text" name="Cc" class="form-control form-control-sm"
                                   placeholder="optional, comma-separated" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Subject <span class="text-danger">*</span></label>
                            <input type="text" name="Subject" class="form-control form-control-sm" value="@vchSubject" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Body</label>
                            <div class="email-quill-host"><div id="voucherBodyEditor"></div></div>
                            <input type="hidden" name="Body" id="voucherBodyHidden" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="AttachPdf" id="vchAttachPdf" value="true" checked />
                                <input type="hidden" name="AttachPdf" value="false" />
                                <label class="form-check-label small" for="vchAttachPdf">
                                    <i class="bi bi-file-earmark-pdf me-1 text-danger"></i>
                                    Attach <strong>Voucher-@(Model.BookingNumber).pdf</strong>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="bookingVoucherEmailResult" class="mt-3 small"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning px-4" id="bookingVoucherEmailSendBtn">
                        <i class="bi bi-send me-1"></i>Send
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
    <script>
        const emailToolbar = [
            [{ header: [false, 1, 2, 3] }],
            ['bold', 'italic', 'underline'],
            [{ list: 'ordered' }, { list: 'bullet' }],
            ['link', 'clean']
        ];

        // Two Quill editors — one per email modal. Initialized once on page load
        // so the toolbar measurements are correct by the time the modal opens.
        const invQuill = new Quill('#invoiceBodyEditor',  { theme: 'snow', modules: { toolbar: emailToolbar } });
        const vchQuill = new Quill('#voucherBodyEditor',  { theme: 'snow', modules: { toolbar: emailToolbar } });

        const invBodyInit = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(invBody));
        const vchBodyInit = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(vchBody));
        if (invBodyInit) invQuill.clipboard.dangerouslyPasteHTML(invBodyInit);
        if (vchBodyInit) vchQuill.clipboard.dangerouslyPasteHTML(vchBodyInit);

        function quillHtml(q) {
            const html = q.root.innerHTML.trim();
            return (html === '<p><br></p>') ? '' : html;
        }

        function wireEmailForm(formId, sendBtnId, resultId, modalId, endpoint, quill, hiddenId) {
            const f = document.getElementById(formId);
            if (!f) return;
            f.addEventListener('submit', async (e) => {
                e.preventDefault();
                document.getElementById(hiddenId).value = quillHtml(quill);

                const out = document.getElementById(resultId);
                const btn = document.getElementById(sendBtnId);
                const orig = btn.innerHTML;
                btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending… (PDF render takes ~5s)';
                out.innerHTML = '';
                try {
                    const r = await fetch(endpoint, { method: 'POST', body: new FormData(f) });
                    const j = await r.json();
                    if (j.success) {
                        out.innerHTML = '<div class="alert alert-success py-2 mb-0"><i class="bi bi-check-circle-fill me-1"></i>Email sent.</div>';
                        setTimeout(() => bootstrap.Modal.getInstance(document.getElementById(modalId)).hide(), 1200);
                    } else {
                        out.innerHTML = `<div class="alert alert-danger py-2 mb-0"><i class="bi bi-exclamation-triangle-fill me-1"></i>${j.error || 'Send failed'}</div>`;
                    }
                } catch (ex) {
                    out.innerHTML = `<div class="alert alert-danger py-2 mb-0">${ex.message || ex}</div>`;
                } finally {
                    btn.disabled = false; btn.innerHTML = orig;
                }
            });
        }
        wireEmailForm('bookingEmailForm',        'bookingEmailSendBtn',        'bookingEmailResult',        'bookingEmailModal',        '/Bookings/@Model.Id/SendEmail',         invQuill, 'invoiceBodyHidden');
        wireEmailForm('bookingVoucherEmailForm', 'bookingVoucherEmailSendBtn', 'bookingVoucherEmailResult', 'bookingVoucherEmailModal', '/Bookings/@Model.Id/SendVoucherEmail', vchQuill, 'voucherBodyHidden');
    </script>
}

<div class="row g-3">
    <div class="col-lg-8">
        <!-- Trip / customer summary -->
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="small text-muted">Mobile</div>
                        <div class="fw-semibold">@(Model.CustomerMobile ?? "—")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="small text-muted">Email</div>
                        <div class="fw-semibold">@(Model.CustomerEmail ?? "—")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Destination</div>
                        <div class="fw-semibold">@(Model.DestinationName ?? "—")</div>
                    </div>
                    <div class="col-md-2">
                        <div class="small text-muted">Travelers</div>
                        <div class="fw-semibold">@Model.TotalPax (@Model.Adults A · @Model.Children C · @Model.Infants I)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Travel Start</div>
                        <div class="fw-semibold">@(Model.StartDate?.ToString("dd MMM yyyy") ?? "—")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Travel End</div>
                        <div class="fw-semibold">@(Model.EndDate?.ToString("dd MMM yyyy") ?? "—")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Days / Nights</div>
                        <div class="fw-semibold">@(Model.Days?.ToString() ?? "—") / @(Model.Nights?.ToString() ?? "—")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Option Booked</div>
                        <div class="fw-semibold">@(Model.OptionName ?? "—")</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="col-12">
                            <div class="small text-muted">Notes</div>
                            <div>@Model.Notes</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Installments -->
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-cash-stack text-primary me-2"></i>Payment Plan</h6>
                @if (canEdit)
                {
                    <a href="/Bookings/Edit/@Model.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Edit Installments
                    </a>
                }
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px">No.</th>
                            <th>Mode</th>
                            <th>Status</th>
                            <th class="text-end">Amount</th>
                            <th>Due</th>
                            <th>Received</th>
                            <th>Remark</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Installments.Any())
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">No installments yet — click <em>Edit</em> to add a payment plan.</td></tr>
                        }
                        else
                        {
                            foreach (var i in Model.Installments)
                            {
                                <tr>
                                    <td class="fw-bold">@i.InstallmentNo</td>
                                    <td>@(i.PaymentMode ?? "—")</td>
                                    <td><span class="badge @PayBadge(i.PaymentStatus)">@i.PaymentStatus</span></td>
                                    <td class="text-end fw-semibold">@Model.Currency @i.Amount.ToString("N2")</td>
                                    <td>@(i.DueDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                    <td>@(i.ReceivedDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                    <td class="small text-muted">@(i.Remark ?? "—")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Money summary -->
        <div class="card shadow-sm mb-3 border-primary">
            <div class="card-body">
                <h6 class="fw-bold text-muted mb-3"><i class="bi bi-receipt-cutoff text-primary me-2"></i>Summary</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Total</span>
                    <span class="fw-bold">@Model.Currency @Model.TotalAmount.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between mb-2 text-success">
                    <span>Paid</span>
                    <span class="fw-bold">@Model.Currency @Model.PaidAmount.ToString("N2")</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between fs-5 fw-bold @(Model.BalanceAmount > 0 ? "text-danger" : "text-success")">
                    <span>Balance</span>
                    <span>@Model.Currency @Model.BalanceAmount.ToString("N2")</span>
                </div>
            </div>
        </div>

        <!-- Recent emails -->
        @await Html.PartialAsync("_EmailLogPanel", ViewBag.EmailLogs as IEnumerable<TravelERP.Core.Entities.Tenant.EmailLog> ?? Enumerable.Empty<TravelERP.Core.Entities.Tenant.EmailLog>())

        <!-- Audit -->
        <div class="card shadow-sm bg-light border-0">
            <div class="card-body small">
                <div class="text-muted mb-1">Created</div>
                <div class="mb-2">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                @if (Model.UpdatedAt.HasValue)
                {
                    <div class="text-muted mb-1">Last updated</div>
                    <div>@Model.UpdatedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                }
            </div>
        </div>

        @if (Tenant.CanDelete(TravelERP.Core.Constants.AppModules.Bookings) && Model.Status != "Cancelled")
        {
            <form asp-action="Delete" method="post" class="mt-3" onsubmit="return confirm('Cancel this booking? It will be archived.');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                    <i class="bi bi-x-circle me-1"></i>Cancel Booking
                </button>
            </form>
        }
    </div>
</div>
