@using TravelERP.Core.Entities.Master
@using TravelERP.Core.Entities.Tenant
@model Booking
@{
    Layout = null;
    var company = ViewBag.Company as Company;
    var hotels  = Model.Hotels ?? new List<BookingHotel>();
    ViewData["Title"] = $"Voucher {Model.BookingNumber}";

    // Per-hotel check-in / check-out (cumulative from booking start)
    var startDate = Model.StartDate ?? DateTime.UtcNow.Date;
    var hotelStops = new List<(BookingHotel H, DateTime CheckIn, DateTime CheckOut, int FromDay, int ToDay)>();
    {
        var cursor = startDate;
        var dayCursor = 1;
        foreach (var h in hotels)
        {
            var nights = h.Nights > 0 ? h.Nights : 1;
            var checkOut = cursor.AddDays(nights);
            var fromDay = dayCursor;
            var toDay   = dayCursor + nights;
            hotelStops.Add((h, cursor, checkOut, fromDay, toDay));
            cursor = checkOut;
            dayCursor = toDay;
        }
    }

    string Mr(string name) =>
        string.IsNullOrWhiteSpace(name) ? "" : (name.StartsWith("Mr ", StringComparison.OrdinalIgnoreCase)
            || name.StartsWith("Ms ", StringComparison.OrdinalIgnoreCase)
            || name.StartsWith("Mrs ", StringComparison.OrdinalIgnoreCase) ? name : "Mr. " + name);

    var checkInTime  = string.IsNullOrWhiteSpace(company?.VoucherCheckInTime)  ? "02:00 PM" : company.VoucherCheckInTime;
    var checkOutTime = string.IsNullOrWhiteSpace(company?.VoucherCheckOutTime) ? "11:00 AM" : company.VoucherCheckOutTime;
    var hotelNoteHtml = company?.VoucherHotelNote;
    var policyHtml    = company?.VoucherPolicyHtml;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>@ViewData["Title"] — @(company?.Name ?? "Hotel Voucher")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root {
            --brand: #0d6efd;
            --brand-dark: #0a58ca;
            --brand-soft: #eff6ff;
            --ink: #0f172a;
            --muted: #64748b;
            --line: #e5e7eb;
        }
        * { box-sizing: border-box; }
        body {
            background: #f1f5f9; color: var(--ink);
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            -webkit-print-color-adjust: exact; print-color-adjust: exact;
            font-size: 14px;
        }
        .v-page {
            max-width: 920px; margin: 1.25rem auto;
            background: #fff;
            border-radius: 1rem; overflow: hidden;
            box-shadow: 0 8px 32px rgba(15,23,42,.08);
        }

        /* ───── HERO ───── */
        .v-hero {
            position: relative;
            padding: 2rem 2.25rem 2.5rem;
            background: linear-gradient(135deg, #0d6efd 0%, #1e40af 60%, #1e3a8a 100%);
            color: #fff;
            overflow: hidden;
        }
        .v-hero::after {
            content: ''; position: absolute; right: -50px; top: -50px;
            width: 240px; height: 240px; border-radius: 50%;
            background: rgba(255,255,255,.06);
        }
        .v-hero::before {
            content: ''; position: absolute; right: 80px; bottom: -80px;
            width: 180px; height: 180px; border-radius: 50%;
            background: rgba(255,255,255,.05);
        }
        .v-hero-row { position: relative; z-index: 2;
            display: flex; justify-content: space-between; align-items: flex-start; gap: 1.25rem; flex-wrap: wrap;
        }
        .v-logo {
            width: 64px; height: 64px;
            background: #fff; border-radius: .65rem;
            padding: 6px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 12px rgba(0,0,0,.18);
            flex-shrink: 0;
        }
        .v-logo img { max-width: 100%; max-height: 100%; object-fit: contain; }

        .v-eyebrow {
            font-size: .72rem; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; opacity: .75; margin-bottom: .25rem;
        }
        .v-title { font-size: 2.1rem; font-weight: 800; line-height: 1.05; margin: 0 0 .35rem; }
        .v-company { font-size: 1rem; opacity: .9; }

        .v-id-card {
            background: rgba(255,255,255,.13);
            border: 1px solid rgba(255,255,255,.18);
            border-radius: .75rem; padding: .85rem 1.1rem;
            min-width: 220px;
            backdrop-filter: blur(6px);
        }
        .v-id-card .lbl { font-size: .65rem; text-transform: uppercase; letter-spacing: 1px; opacity: .8; }
        .v-id-card .num { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 1.05rem; font-weight: 700; }
        .v-id-card .row + .row { margin-top: .25rem; }

        /* Customer pill on hero */
        .v-customer-pill {
            position: relative; z-index: 2;
            margin-top: 1.25rem;
            display: inline-flex; align-items: center; gap: .65rem;
            background: rgba(255,255,255,.18); border: 1px solid rgba(255,255,255,.22);
            backdrop-filter: blur(6px);
            padding: .55rem 1rem; border-radius: 999px;
        }
        .v-customer-pill .av {
            width: 32px; height: 32px; border-radius: 50%;
            background: rgba(255,255,255,.95); color: var(--brand);
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: .85rem;
        }
        .v-customer-pill .nm { font-weight: 700; font-size: .95rem; }

        /* ───── BODY ───── */
        .v-body { padding: 1.75rem 2.25rem; }
        .v-section-head {
            display: flex; align-items: center; gap: .55rem;
            margin: 1.5rem 0 .75rem; font-weight: 700; font-size: 1.05rem; color: var(--ink);
        }
        .v-section-head:first-child { margin-top: 0; }
        .v-section-head .ico {
            width: 28px; height: 28px; border-radius: .45rem;
            background: var(--brand-soft); color: var(--brand);
            display: flex; align-items: center; justify-content: center;
            font-size: .9rem;
        }

        /* ───── HOTEL CARD ───── */
        .h-card {
            border: 1px solid var(--line); border-radius: .9rem;
            margin-bottom: 1rem; overflow: hidden;
            background: #fff;
        }
        .h-card .h-strip {
            height: 6px;
            background: linear-gradient(90deg, #0d6efd 0%, #6366f1 50%, #06b6d4 100%);
        }
        .h-card .h-body { padding: 1.1rem 1.25rem; }
        .h-card .h-head {
            display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;
            margin-bottom: 1rem; flex-wrap: wrap;
        }
        .h-card .h-name {
            font-size: 1.35rem; font-weight: 800; color: var(--ink); margin: 0 0 .15rem;
        }
        .h-card .h-loc { color: var(--muted); font-size: .9rem; }
        .h-card .h-loc i { color: var(--brand); }
        .h-card .h-cnf {
            background: var(--brand-soft); color: var(--brand-dark);
            border: 1px solid #cfe2ff;
            font-family: ui-monospace, SFMono-Regular, monospace;
            font-size: .78rem; font-weight: 700;
            padding: .35rem .65rem; border-radius: .5rem;
            white-space: nowrap;
        }
        .h-card .h-cnf .l { font-size: .6rem; opacity: .7; text-transform: uppercase; letter-spacing: .8px; display: block; }

        /* Date strip */
        .h-dates {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 0;
            background: #f8fafc; border: 1px solid var(--line);
            border-radius: .65rem; padding: .85rem 1rem;
            margin-bottom: 1rem;
        }
        .h-dates .col { display: flex; flex-direction: column; }
        .h-dates .col.right { align-items: flex-end; text-align: right; }
        .h-dates .lbl {
            font-size: .65rem; text-transform: uppercase; letter-spacing: 1px;
            color: var(--muted); font-weight: 700; margin-bottom: .15rem;
        }
        .h-dates .day { font-size: .85rem; color: var(--muted); }
        .h-dates .date { font-size: 1.35rem; font-weight: 800; color: var(--ink); line-height: 1; }
        .h-dates .time { font-size: .8rem; color: var(--brand); font-weight: 600; margin-top: .15rem; }
        .h-dates .arrow {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            color: var(--brand); padding: 0 .65rem; min-width: 90px;
        }
        .h-dates .arrow .nights {
            background: var(--brand); color: #fff; font-size: .68rem; font-weight: 700;
            padding: 2px 10px; border-radius: 999px;
            text-transform: uppercase; letter-spacing: .8px;
            margin-top: .35rem;
        }
        .h-dates .arrow i { font-size: 1.4rem; }

        /* Pills row */
        .h-pills {
            display: flex; gap: .5rem; flex-wrap: wrap;
        }
        .h-pill {
            display: inline-flex; align-items: center; gap: .4rem;
            background: #f1f5f9; border: 1px solid var(--line);
            color: var(--ink); font-size: .82rem; font-weight: 600;
            padding: .4rem .75rem; border-radius: 999px;
        }
        .h-pill i { color: var(--brand); }
        .h-pill strong { color: var(--brand-dark); }

        .h-note {
            margin-top: 1rem; padding: .85rem 1rem;
            background: #fffbeb; border-left: 3px solid #f59e0b;
            border-radius: .35rem;
            font-size: .85rem; color: #78350f; line-height: 1.55;
        }
        .h-note .lbl {
            display: inline-flex; align-items: center; gap: .35rem;
            font-weight: 700; color: #92400e; margin-right: .35rem;
        }

        /* ───── INFO STRIP (Booked & Payable / Customer Service) ───── */
        .info-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
            margin: 1.25rem 0;
        }
        .info-card {
            background: #fff; border: 1px solid var(--line); border-radius: .75rem;
            padding: 1rem 1.1rem;
        }
        .info-card .lbl {
            font-size: .68rem; text-transform: uppercase; letter-spacing: 1px;
            color: var(--muted); font-weight: 700; margin-bottom: .35rem;
            display: flex; align-items: center; gap: .35rem;
        }
        .info-card .lbl i { color: var(--brand); }
        .info-card strong { color: var(--ink); display: block; margin-bottom: .1rem; }
        .info-card .text { font-size: .87rem; color: #334155; line-height: 1.55; }

        /* ───── POLICY LIST ───── */
        .policy-block {
            background: #f8fafc; border: 1px solid var(--line); border-radius: .75rem;
            padding: 1rem 1.25rem;
            font-size: .87rem; color: #334155; line-height: 1.6;
        }
        .policy-block ul, .policy-block ol { padding-left: 1.5rem; margin: 0; }
        .policy-block ul li, .policy-block ol li { margin-bottom: .35rem; }
        .policy-block ul {
            list-style: none; padding-left: 0;
        }
        .policy-block ul li {
            position: relative; padding-left: 1.65rem;
        }
        .policy-block ul li::before {
            content: '\F26B'; /* bi-check-circle-fill */
            font-family: 'bootstrap-icons';
            color: #10b981; position: absolute; left: 0; top: 1px;
        }

        /* ───── FOOTER ───── */
        .v-footer {
            background: #f8fafc; border-top: 1px solid var(--line);
            padding: 1.5rem 2.25rem;
        }
        .v-footer-row {
            display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
            font-size: .85rem;
        }
        .v-footer .lbl {
            font-size: .65rem; text-transform: uppercase; letter-spacing: 1px;
            color: var(--muted); font-weight: 700; margin-bottom: .15rem;
        }
        .v-footer strong { color: var(--ink); }
        .v-emergency {
            margin-top: 1.25rem; padding: .75rem;
            text-align: center; background: var(--brand); color: #fff;
            border-radius: .5rem; font-size: .82rem; font-weight: 600;
        }
        .v-emergency a { color: #fff; text-decoration: none; }

        /* ───── TOOLBAR (auth-only) ───── */
        .toolbar {
            position: sticky; top: 0; background: #fff;
            border-bottom: 1px solid var(--line); padding: .65rem 1.25rem;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 10;
        }

        /* Pagination — keep cards intact across PDF page breaks. Outside the
           print media query so Puppeteer's screen-media render still honors them. */
        .h-card,
        .info-card,
        .policy-block,
        .h-dates,
        .h-note,
        .v-footer,
        .v-customer-pill {
            break-inside: avoid;
            page-break-inside: avoid;
        }
        .v-section-head { break-after: avoid; page-break-after: avoid; }

        @@media print {
            body { background: #fff !important; }
            .toolbar { display: none !important; }
            .v-page { box-shadow: none; margin: 0; max-width: none; border-radius: 0; }
        }
        @@page { size: A4; margin: 0; }
        @@media (max-width: 575px) {
            .v-body, .v-footer, .v-hero { padding-left: 1.25rem; padding-right: 1.25rem; }
            .info-grid, .v-footer-row { grid-template-columns: 1fr; }
            .h-dates { grid-template-columns: 1fr; gap: .5rem; }
            .h-dates .col.right { align-items: flex-start; text-align: left; }
            .h-dates .arrow { flex-direction: row; min-width: 0; gap: .5rem; }
            .h-dates .arrow i { transform: rotate(90deg); }
        }
    </style>
</head>
<body>

@{
    // Hide the toolbar when the page is being rendered for PDF export.
    var isPdfRender = string.Equals(Context.Request.Query["pdf"], "1", StringComparison.Ordinal);
}
@if (User.Identity?.IsAuthenticated == true && !isPdfRender)
{
    <div class="toolbar">
        <span class="text-muted small"><i class="bi bi-receipt-cutoff text-success me-1"></i>Internal preview</span>
        <div class="d-flex gap-2">
            <a href="/Bookings/Details/@Model.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
            <a href="/Bookings/@Model.Id/voucher/pdf" class="btn btn-sm btn-primary"><i class="bi bi-file-earmark-pdf me-1"></i>Download PDF</a>
        </div>
    </div>
}

<div class="v-page">

    <!-- HERO -->
    <header class="v-hero">
        <div class="v-hero-row">
            <div class="d-flex align-items-start gap-3">
                @if (!string.IsNullOrEmpty(company?.LogoUrl))
                {
                    <div class="v-logo"><img src="@company.LogoUrl" alt="@company.Name" /></div>
                }
                else
                {
                    <div class="v-logo" style="background: rgba(255,255,255,.95);">
                        <i class="bi bi-airplane-fill" style="font-size:1.8rem;color:var(--brand)"></i>
                    </div>
                }
                <div>
                    <div class="v-eyebrow">Hotel Voucher</div>
                    <h1 class="v-title">Your Stay is Booked</h1>
                    <div class="v-company">@(company?.Name ?? "")</div>
                </div>
            </div>

            <div class="v-id-card">
                <div class="row d-flex justify-content-between gap-3">
                    <div><div class="lbl">Booking ID</div><div class="num">@Model.BookingNumber</div></div>
                </div>
                <div class="row d-flex justify-content-between gap-3">
                    <div><div class="lbl">Issued</div><div class="num">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div></div>
                </div>
                <div class="row d-flex justify-content-between gap-3">
                    <div><div class="lbl">Status</div><div class="num text-uppercase">@Model.Status</div></div>
                </div>
            </div>
        </div>

        <div class="v-customer-pill">
            <div class="av">
                @{
                    var initials = string.Concat((Model.CustomerName ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
                    if (string.IsNullOrEmpty(initials)) initials = "?";
                }
                @initials
            </div>
            <div>
                <div style="font-size:.65rem;opacity:.85;text-transform:uppercase;letter-spacing:1px">Guest</div>
                <div class="nm">@Mr(Model.CustomerName)</div>
            </div>
        </div>
    </header>

    <!-- BODY -->
    <div class="v-body">

        <!-- Trip summary banner -->
        <div class="v-section-head"><span class="ico"><i class="bi bi-suitcase-fill"></i></span>Stay Details</div>

        @if (!hotelStops.Any())
        {
            <div class="alert alert-warning small">
                No hotel rows snapshot on this booking. Open the booking, click <strong>Edit</strong>, save, and the snapshot will be re-created from the package option.
            </div>
        }
        else
        {
            @foreach (var (h, ci, co, fromDay, toDay) in hotelStops)
            {
                var rooms     = h.Rooms     > 0 ? h.Rooms     : 1;
                var extraBeds = h.ExtraBeds >= 0 ? h.ExtraBeds : 0;
                var cnfNo     = string.IsNullOrWhiteSpace(h.HotelCnfNo) ? Model.BookingNumber : h.HotelCnfNo;
                var nights    = h.Nights > 0 ? h.Nights : 1;

                <div class="h-card">
                    <div class="h-strip"></div>
                    <div class="h-body">
                        <div class="h-head">
                            <div>
                                <h3 class="h-name">@(h.HotelName ?? "—")</h3>
                                <div class="h-loc">
                                    <i class="bi bi-geo-alt-fill"></i> @(Model.DestinationName ?? "—")
                                </div>
                            </div>
                            <div class="h-cnf">
                                <span class="l">Hotel Cnf #</span>
                                @cnfNo
                            </div>
                        </div>

                        <!-- Date strip -->
                        <div class="h-dates">
                            <div class="col">
                                <div class="lbl">Check In</div>
                                <div class="day">@ci.ToString("ddd")</div>
                                <div class="date">@ci.ToString("dd MMM")</div>
                                <div class="time"><i class="bi bi-clock me-1"></i>@checkInTime</div>
                            </div>
                            <div class="arrow">
                                <i class="bi bi-arrow-right"></i>
                                <span class="nights">@nights night@(nights == 1 ? "" : "s")</span>
                            </div>
                            <div class="col right">
                                <div class="lbl">Check Out</div>
                                <div class="day">@co.ToString("ddd")</div>
                                <div class="date">@co.ToString("dd MMM")</div>
                                <div class="time"><i class="bi bi-clock me-1"></i>@checkOutTime</div>
                            </div>
                        </div>

                        <!-- Pills row -->
                        <div class="h-pills">
                            @if (!string.IsNullOrEmpty(h.RoomTypeName))
                            {
                                <span class="h-pill"><i class="bi bi-door-open"></i>@h.RoomTypeName</span>
                            }
                            @if (!string.IsNullOrEmpty(h.MealPlanCode) || !string.IsNullOrEmpty(h.MealPlanName))
                            {
                                <span class="h-pill"><i class="bi bi-cup-hot"></i>@(h.MealPlanName ?? h.MealPlanCode)</span>
                            }
                            <span class="h-pill"><i class="bi bi-key"></i><strong>@rooms</strong> Room@(rooms == 1 ? "" : "s")</span>
                            @if (extraBeds > 0)
                            {
                                <span class="h-pill"><i class="bi bi-plus-square"></i><strong>@extraBeds</strong> Extra Bed@(extraBeds == 1 ? "" : "s")</span>
                            }
                            <span class="h-pill"><i class="bi bi-person-fill"></i><strong>@Model.Adults</strong> Adult@(Model.Adults == 1 ? "" : "s")</span>
                            @if (Model.Children > 0)
                            {
                                <span class="h-pill"><i class="bi bi-emoji-smile"></i><strong>@Model.Children</strong> Child@(Model.Children == 1 ? "" : "ren")</span>
                            }
                            @if (Model.Infants > 0)
                            {
                                <span class="h-pill"><i class="bi bi-balloon"></i><strong>@Model.Infants</strong> Infant@(Model.Infants == 1 ? "" : "s")</span>
                            }
                        </div>

                        <!-- Note -->
                        <div class="h-note">
                            <span class="lbl"><i class="bi bi-info-circle-fill"></i>Note</span>
                            @if (!string.IsNullOrWhiteSpace(hotelNoteHtml))
                            {
                                @Html.Raw(hotelNoteHtml)
                            }
                            else
                            {
                                <span>This booking is Non-Refundable and cannot be amended or modified. Failure to arrive at your hotel will be treated as a No-Show and no refund will be given as per hotel policy.</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(h.OtherText))
                            {
                                <div class="mt-1 fst-italic" style="color:#92400e">@h.OtherText</div>
                            }
                        </div>
                    </div>
                </div>
            }
        }

        <!-- Booked & Customer Service -->
        <div class="info-grid">
            <div class="info-card">
                <div class="lbl"><i class="bi bi-building"></i>Booked &amp; Payable By</div>
                @if (company != null)
                {
                    <strong>@company.Name</strong>
                    if (!string.IsNullOrWhiteSpace(company.Address))
                    {
                        <div class="text">@company.Address</div>
                    }
                    var loc = string.Join(", ", new[] { company.City, company.Country }.Where(x => !string.IsNullOrEmpty(x)));
                    if (!string.IsNullOrEmpty(loc))
                    {
                        <div class="text">@loc</div>
                    }
                }
            </div>
            <div class="info-card">
                <div class="lbl"><i class="bi bi-headset"></i>Customer Support</div>
                @if (!string.IsNullOrEmpty(company?.Phone))
                {
                    <strong>@company.Phone</strong>
                }
                @if (!string.IsNullOrEmpty(company?.Email))
                {
                    <div class="text"><i class="bi bi-envelope me-1"></i>@company.Email</div>
                }
                <div class="text small text-muted mt-1">All special requests are subject to availability upon arrival.</div>
            </div>
        </div>

        <!-- Policy -->
        <div class="v-section-head"><span class="ico"><i class="bi bi-list-check"></i></span>Check-in &amp; Check-out Policy</div>
        <div class="policy-block">
            @if (!string.IsNullOrWhiteSpace(policyHtml))
            {
                @Html.Raw(policyHtml)
            }
            else
            {
                <ul class="mb-0">
                    <li>The usual check-in time is @checkInTime however this might vary from hotel to hotel and with different destinations. Rooms may not be available for early check-in unless especially required in advance.</li>
                    <li>Reservation may be canceled automatically after 18:00 hours if hotel is not informed about the approximate time of late arrivals.</li>
                    <li>Early Check-in &amp; Check-out is subject to room availability / Hotel Policy.</li>
                    <li>Any late checkout may involve additional charges. Please check with the hotel reception in advance.</li>
                    <li>For specific queries related to a particular hotel, kindly reach out to local support team for further assistance.</li>
                    <li>No refund will be given for any cancellation once the trip starts; cancellation will be done as per our Cancellation Policy.</li>
                    <li>We are a Tour operator, we don't own any hotels, vehicles, airlines so T&amp;C will be applicable as per their payment policy.</li>
                </ul>
            }
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="v-footer">
        <div class="v-footer-row">
            <div>
                <div class="lbl"><i class="bi bi-building me-1"></i>Company</div>
                <strong>@(company?.Name ?? "")</strong>
                @if (!string.IsNullOrEmpty(company?.Address))
                {
                    <div class="text-muted small mt-1">@company.Address</div>
                }
                @if (!string.IsNullOrEmpty(company?.City))
                {
                    <div class="text-muted small">@company.City@(string.IsNullOrEmpty(company?.Country) ? "" : ", " + company.Country)</div>
                }
            </div>
            <div>
                <div class="lbl"><i class="bi bi-people-fill me-1"></i>Trip Coordinator</div>
                <strong>Team @(company?.Name?.Split(' ').FirstOrDefault() ?? "")</strong>
                @if (!string.IsNullOrEmpty(company?.Phone))
                {
                    <div class="text-muted small mt-1"><i class="bi bi-telephone me-1"></i>@company.Phone</div>
                }
                @if (!string.IsNullOrEmpty(company?.Email))
                {
                    <div class="text-muted small"><i class="bi bi-envelope me-1"></i>@company.Email</div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(company?.Phone) || !string.IsNullOrEmpty(company?.Email))
        {
            <div class="v-emergency">
                <i class="bi bi-telephone-fill me-2"></i>
                Emergency 24/7
                @if (!string.IsNullOrEmpty(company?.Phone)) { <span class="ms-2">@company.Phone</span> }
                @if (!string.IsNullOrEmpty(company?.Email)) { <span class="ms-3"><i class="bi bi-envelope-fill me-1"></i>@company.Email</span> }
            </div>
        }
    </footer>
</div>

</body>
</html>
