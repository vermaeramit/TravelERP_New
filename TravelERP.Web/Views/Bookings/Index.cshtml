@using TravelERP.Core.Common
@model PagedResult<TravelERP.Core.Entities.Tenant.Booking>
@inject TravelERP.Core.Interfaces.ITenantContext Tenant
@{
    ViewData["Title"] = "Bookings";
    var search = ViewBag.Search as string;
    var status = ViewBag.Status as string;

    string StatusBadge(string s) => s?.ToLowerInvariant() switch
    {
        "confirmed" => "bg-success-subtle text-success",
        "completed" => "bg-primary-subtle text-primary",
        "cancelled" => "bg-danger-subtle text-danger",
        _           => "bg-secondary-subtle text-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0 small">Confirmed bookings — payments tracked via installments.</p>
</div>

<form method="get" class="card shadow-sm mb-3">
    <div class="card-body py-3 d-flex gap-2 flex-wrap">
        <input type="text" name="search" value="@search" class="form-control form-control-sm" style="max-width: 320px;"
               placeholder="Search by booking #, invoice #, customer, mobile…" />
        <select name="status" class="form-select form-select-sm" style="max-width: 180px;">
            <option value="">All statuses</option>
            <option value="Confirmed" selected="@(status == "Confirmed")">Confirmed</option>
            <option value="Completed" selected="@(status == "Completed")">Completed</option>
            <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
        </select>
        <button type="submit" class="btn btn-sm btn-primary px-3"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(status))
        {
            <a href="/Bookings" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-journal-bookmark fs-1 d-block mb-2 opacity-50"></i>
            <p class="mb-0">No bookings yet. Open a Lead → pick a Package option → click <strong>Convert to Booking</strong>.</p>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Booking #</th>
                        <th>Lead / Trip</th>
                        <th>Customer</th>
                        <th>Destination</th>
                        <th>Travel</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">Paid</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Items)
                    {
                        <tr>
                            <td>
                                <a href="/Bookings/Details/@b.Id" class="text-decoration-none fw-bold font-monospace">@b.BookingNumber</a>
                                <div class="small text-muted font-monospace">@b.InvoiceNumber</div>
                            </td>
                            <td>
                                @if (b.LeadId.HasValue && !string.IsNullOrEmpty(b.LeadNumber))
                                {
                                    <a href="/Leads/Details/@b.LeadId" class="text-decoration-none small font-monospace">
                                        <i class="bi bi-funnel me-1 text-muted"></i>@b.LeadNumber
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                                @if (b.PackageId.HasValue && !string.IsNullOrEmpty(b.PackageNumber))
                                {
                                    <div>
                                        <a href="/Packages/Details/@b.PackageId" class="text-decoration-none small font-monospace">
                                            <i class="bi bi-suitcase me-1 text-muted"></i>@b.PackageNumber
                                        </a>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@b.CustomerName</div>
                                @if (!string.IsNullOrEmpty(b.CustomerMobile))
                                {
                                    <div class="small text-muted"><i class="bi bi-telephone me-1"></i>@b.CustomerMobile</div>
                                }
                            </td>
                            <td>@(b.DestinationName ?? "—")</td>
                            <td>
                                @if (b.StartDate.HasValue)
                                {
                                    <div>@b.StartDate.Value.ToString("dd MMM yyyy")</div>
                                    @if (b.Days.HasValue) { <div class="small text-muted">@b.Days days</div> }
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-end fw-bold">@b.Currency @b.TotalAmount.ToString("N0")</td>
                            <td class="text-end">
                                <span class="text-success fw-semibold">@b.Currency @b.PaidAmount.ToString("N0")</span>
                                @if (b.BalanceAmount > 0)
                                {
                                    <div class="small text-danger">balance @b.BalanceAmount.ToString("N0")</div>
                                }
                            </td>
                            <td><span class="badge @StatusBadge(b.Status)">@b.Status</span></td>
                            <td class="small text-muted">@b.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a href="/Bookings/Details/@b.Id" class="btn btn-outline-secondary" title="View Booking">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (b.LeadId.HasValue)
                                    {
                                        <a href="/Leads/Details/@b.LeadId" class="btn btn-outline-secondary" title="View Lead">
                                            <i class="bi bi-funnel"></i>
                                        </a>
                                    }
                                    @if (b.PackageId.HasValue)
                                    {
                                        <a href="/Packages/Details/@b.PackageId" class="btn btn-outline-secondary" title="View Package">
                                            <i class="bi bi-suitcase"></i>
                                        </a>
                                    }
                                    @if (Tenant.CanEdit(TravelERP.Core.Constants.AppModules.Bookings))
                                    {
                                        <a href="/Bookings/Edit/@b.Id" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" href="?search=@search&status=@status&page=@(Model.Page - 1)"><i class="bi bi-chevron-left"></i></a>
                </li>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" href="?search=@search&status=@status&page=@p">@p</a>
                    </li>
                }
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" href="?search=@search&status=@status&page=@(Model.Page + 1)"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    }
}
