@model IEnumerable<TravelERP.Core.Entities.Tenant.Booking>
@using TravelERP.Shared.Enums
@{
    ViewData["Title"] = "Bookings";
    var sym = ViewBag.CurrencySymbol as string ?? "";
}
<div class="card shadow-sm">
    <div class="card-header bg-transparent border-0 section-header">
        <h5><i class="bi bi-journal-bookmark-fill text-primary me-2"></i>Booking Management</h5>
        <a href="/Bookings/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>New Booking
        </a>
    </div>
    <div class="card-header bg-transparent py-2">
        <div class="d-flex flex-wrap gap-2">
            <a href="/Bookings" class="btn btn-sm @(ViewBag.StatusFilter == null ? "btn-primary" : "btn-outline-secondary")">All</a>
            @foreach (var s in Enum.GetValues<BookingStatus>())
            {
                <a href="/Bookings?status=@s" class="btn btn-sm @(ViewBag.StatusFilter == s.ToString() ? "btn-primary" : "btn-outline-secondary")">@s</a>
            }
        </div>
    </div>
    <div class="card-body">
        <table class="table table-hover dt-table">
            <thead>
                <tr>
                    <th>Reference</th><th>Customer</th><th>Destination</th>
                    <th>Travel Date</th><th>Pax</th><th>Amount</th>
                    <th>Status</th><th>Payment</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td><a href="/Bookings/Details/@b.Id" class="fw-semibold text-decoration-none">@b.BookingReference</a></td>
                        <td>@(b.Customer != null ? b.Customer.FullName : b.CustomerId.ToString())</td>
                        <td class="text-truncate" style="max-width:130px">@b.Destination</td>
                        <td>@b.TravelDate.ToString("dd MMM yyyy")</td>
                        <td>@b.Adults A @(b.Children > 0 ? $"/ {b.Children} C" : "")</td>
                        <td class="fw-semibold">@sym@b.TotalAmount.ToString("N0")</td>
                        <td><span class="badge @GetStatusBadge(b.Status)">@b.Status</span></td>
                        <td><span class="badge @GetPayBadge(b.PaymentStatus)">@b.PaymentStatus</span></td>
                        <td>
                            <a href="/Bookings/Details/@b.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a href="/Bookings/Edit/@b.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetStatusBadge(BookingStatus s) => s switch {
        BookingStatus.Confirmed => "bg-success",
        BookingStatus.Pending   => "bg-warning text-dark",
        BookingStatus.Cancelled => "bg-danger",
        BookingStatus.Completed => "bg-primary",
        _                       => "bg-secondary"
    };
    string GetPayBadge(PaymentStatus s) => s switch {
        PaymentStatus.Paid    => "bg-success",
        PaymentStatus.Overdue => "bg-danger",
        PaymentStatus.PartiallyPaid => "bg-warning text-dark",
        _                     => "bg-secondary"
    };
}
