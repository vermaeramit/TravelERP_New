@model TravelERP.Core.Entities.Master.Company
@{ ViewData["Title"] = "Number Series"; }

<form asp-action="NumberSeries" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <div class="col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent border-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-hash text-primary me-2"></i>Number Series Prefixes</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    Configure the prefixes used in auto-generated numbers.
                    Format: <code>{Prefix}-{Year}-{Sequence}</code> — e.g.
                    <code class="text-primary">@(Model?.LeadPrefix ?? "LD")-@DateTime.UtcNow.Year-0001</code>.
                </p>
                <p class="text-muted small mb-3">
                    <strong>Note:</strong> changes apply only to <em>new</em> records.
                    Existing numbers stay as they were.
                </p>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Lead Prefix <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="text" name="leadPrefix" maxlength="20"
                                   value="@(Model?.LeadPrefix ?? "LD")"
                                   class="form-control text-uppercase font-monospace fw-bold series-input" data-target="previewLead"
                                   pattern="[A-Z0-9]{1,20}" required />
                            <span class="input-group-text font-monospace">-@DateTime.UtcNow.Year-0001</span>
                        </div>
                        <small class="text-muted">e.g. LD, LEAD, TRP</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Package Prefix <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="text" name="packagePrefix" maxlength="20"
                                   value="@(Model?.PackagePrefix ?? "PKG")"
                                   class="form-control text-uppercase font-monospace fw-bold series-input" data-target="previewPkg"
                                   pattern="[A-Z0-9]{1,20}" required />
                            <span class="input-group-text font-monospace">-@DateTime.UtcNow.Year-0001</span>
                        </div>
                        <small class="text-muted">e.g. PKG, QT, QUOTE</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Booking Prefix <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="text" name="bookingPrefix" maxlength="20"
                                   value="@(Model?.BookingPrefix ?? "BK")"
                                   class="form-control text-uppercase font-monospace fw-bold series-input" data-target="previewBooking"
                                   pattern="[A-Z0-9]{1,20}" required />
                            <span class="input-group-text font-monospace">-@DateTime.UtcNow.Year-0001</span>
                        </div>
                        <small class="text-muted">e.g. BK, BOOKING, BKG</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Invoice Prefix <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="text" name="invoicePrefix" maxlength="20"
                                   value="@(Model?.InvoicePrefix ?? "INV")"
                                   class="form-control text-uppercase font-monospace fw-bold series-input" data-target="previewInv"
                                   pattern="[A-Z0-9]{1,20}" required />
                            <span class="input-group-text font-monospace">-@DateTime.UtcNow.Year-0001</span>
                        </div>
                        <small class="text-muted">e.g. INV, INVOICE, BL</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a href="/Dashboard" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-1"></i>Save Series
            </button>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm bg-light border-0">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Live Preview</h6>
                <div class="small text-muted mb-1">Next lead number</div>
                <div class="font-monospace fw-bold mb-3" id="previewLead">@(Model?.LeadPrefix ?? "LD")-@DateTime.UtcNow.Year-0001</div>
                <div class="small text-muted mb-1">Next package number</div>
                <div class="font-monospace fw-bold mb-3" id="previewPkg">@(Model?.PackagePrefix ?? "PKG")-@DateTime.UtcNow.Year-0001</div>
                <div class="small text-muted mb-1">Next booking number</div>
                <div class="font-monospace fw-bold mb-3" id="previewBooking">@(Model?.BookingPrefix ?? "BK")-@DateTime.UtcNow.Year-0001</div>
                <div class="small text-muted mb-1">Next invoice number</div>
                <div class="font-monospace fw-bold" id="previewInv">@(Model?.InvoicePrefix ?? "INV")-@DateTime.UtcNow.Year-0001</div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const year = @DateTime.UtcNow.Year;
        const fallback = { previewLead: 'LD', previewPkg: 'PKG', previewBooking: 'BK', previewInv: 'INV' };
        document.querySelectorAll('.series-input').forEach(input => {
            input.addEventListener('input', () => {
                const target = document.getElementById(input.dataset.target);
                if (!target) return;
                const val = (input.value || fallback[input.dataset.target] || '').toUpperCase();
                target.textContent = `${val}-${year}-0001`;
            });
        });
    </script>
}
