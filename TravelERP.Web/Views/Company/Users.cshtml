@using TravelERP.Core.Entities.Master
@using TravelERP.Shared.Enums
@model IEnumerable<MasterUser>
@inject TravelERP.Core.Interfaces.ITenantContext Tenant
@{
    ViewData["Title"] = "Users";
    var users = Model?.ToList() ?? new();

    string RoleBadge(UserRole r) => r switch
    {
        UserRole.SuperAdmin   => "bg-danger-subtle text-danger",
        UserRole.CompanyAdmin => "bg-primary-subtle text-primary",
        UserRole.Manager      => "bg-info-subtle text-info",
        UserRole.Agent        => "bg-success-subtle text-success",
        UserRole.Accountant   => "bg-warning-subtle text-warning",
        UserRole.HRManager    => "bg-purple-subtle text-purple",
        _                     => "bg-secondary-subtle text-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0 small">Users in your company. Each user signs in with their email + password.</p>
    <a href="/Company/Users/Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add User
    </a>
</div>

@if (!users.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-people fs-1 d-block mb-2 opacity-50"></i>
            <p class="mb-0">No users yet. Click <strong>Add User</strong> to invite your first teammate.</p>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:50px"></th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Last Login</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in users)
                    {
                        var isMe = u.Id == Tenant.UserId;
                        var initials = string.Concat((u.FullName ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
                        if (string.IsNullOrEmpty(initials)) initials = "?";
                        <tr>
                            <td>
                                <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center fw-bold"
                                     style="width:36px;height:36px;font-size:.85rem">
                                    @initials
                                </div>
                            </td>
                            <td>
                                <div class="fw-semibold">
                                    @u.FullName
                                    @if (isMe) { <span class="badge bg-info-subtle text-info ms-1 small">you</span> }
                                </div>
                            </td>
                            <td><a href="mailto:@u.Email" class="text-decoration-none">@u.Email</a></td>
                            <td><span class="badge @RoleBadge(u.Role)">@u.Role</span></td>
                            <td class="small">
                                @if (u.LastLoginAt.HasValue)
                                {
                                    @u.LastLoginAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-muted">never</span>
                                }
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success"><i class="bi bi-circle-fill me-1" style="font-size:.45rem"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-circle me-1" style="font-size:.45rem"></i>Disabled</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a href="/Company/Users/Edit/@u.Id" class="btn btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button" class="btn btn-outline-warning"
                                            data-bs-toggle="modal" data-bs-target="#resetPwModal"
                                            data-user-id="@u.Id" data-user-name="@u.FullName"
                                            title="Reset Password">
                                        <i class="bi bi-key"></i>
                                    </button>
                                    @if (!isMe)
                                    {
                                        <form asp-action="ToggleUserActive" method="post" class="d-inline"
                                              onsubmit="return confirm('@(u.IsActive ? "Deactivate" : "Activate") @u.FullName?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <button type="submit" class="btn btn-outline-secondary" title="@(u.IsActive ? "Deactivate" : "Activate")">
                                                <i class="bi @(u.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                            </button>
                                        </form>
                                        <form asp-action="DeleteUser" method="post" class="d-inline"
                                              onsubmit="return confirm('Permanently remove @u.FullName?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <button type="submit" class="btn btn-outline-danger" title="Remove">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Reset Password Modal (single, populated from data-* attributes) -->
<div class="modal fade" id="resetPwModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="resetPwForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="resetPwUserId" />
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-key-fill text-warning me-2"></i>Reset Password
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">Resetting password for <strong id="resetPwUserName"></strong>. They'll need to use the new password to sign in.</p>
                    <label class="form-label small fw-semibold">New Password <span class="text-danger">*</span></label>
                    <input type="password" name="newPassword" id="newPasswordInput" class="form-control" required minlength="6" autocomplete="new-password" />
                    <small class="text-muted">Minimum 6 characters.</small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-key me-1"></i>Reset Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const resetModal = document.getElementById('resetPwModal');
        const userIdEl   = document.getElementById('resetPwUserId');
        const userNameEl = document.getElementById('resetPwUserName');
        const pwForm     = document.getElementById('resetPwForm');
        resetModal?.addEventListener('show.bs.modal', e => {
            const trigger = e.relatedTarget;
            const id = trigger.getAttribute('data-user-id');
            userIdEl.value = id;
            userNameEl.textContent = trigger.getAttribute('data-user-name');
            pwForm.action = `/Company/Users/ResetPassword/${id}`;
            document.getElementById('newPasswordInput').value = '';
        });
    </script>
}
