@model TravelERP.Core.Entities.Master.Company
@{ ViewData["Title"] = "Company Settings"; }

<form asp-action="Settings" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm small py-2 mb-3"></div>

    <div class="col-lg-8">
        <!-- IDENTITY -->
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent border-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-building text-primary me-2"></i>Company Profile</h6>
                <small class="text-muted">Basic info that appears on quotes, invoices and vouchers.</small>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label small fw-semibold">Company Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Slug</label>
                        <input value="@Model.Slug" class="form-control" disabled />
                        <small class="text-muted">URL identifier — not editable.</small>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label small fw-semibold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label small fw-semibold">Phone</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Address" class="form-label small fw-semibold">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="City" class="form-label small fw-semibold">City</label>
                        <input asp-for="City" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Country" class="form-label small fw-semibold">Country</label>
                        <input asp-for="Country" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <!-- COMPLIANCE / LOCALE -->
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent border-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-globe text-primary me-2"></i>Compliance &amp; Locale</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="LicenseNumber" class="form-label small fw-semibold">License Number</label>
                        <input asp-for="LicenseNumber" class="form-control" placeholder="IATA / DGCA / TAFI ..." />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TaxNumber" class="form-label small fw-semibold">Tax / GST Number</label>
                        <input asp-for="TaxNumber" class="form-control" placeholder="GSTIN / VAT" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TimeZone" class="form-label small fw-semibold">Time Zone</label>
                        <input asp-for="TimeZone" class="form-control" placeholder="Asia/Kolkata" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Currency" class="form-label small fw-semibold">Currency Code</label>
                        <input asp-for="Currency" class="form-control" placeholder="INR" maxlength="10" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CurrencySymbol" class="form-label small fw-semibold">Currency Symbol</label>
                        <input asp-for="CurrencySymbol" class="form-control" maxlength="10" />
                    </div>
                </div>
            </div>
        </div>

        <!-- SECURITY / LOGIN -->
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent border-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-shield-lock text-primary me-2"></i>Login Security</h6>
                <small class="text-muted">Controls how your team signs in to the CRM.</small>
            </div>
            <div class="card-body">
                <div class="form-check form-switch">
                    @Html.CheckBoxFor(m => m.RequireOtpLogin, new { @class = "form-check-input", role = "switch", id = "RequireOtpLogin" })
                    <label for="RequireOtpLogin" class="form-check-label fw-semibold">
                        Require email OTP on every login
                    </label>
                </div>
                <small class="text-muted d-block mt-1">
                    When enabled, after entering email + password every user gets a 6-digit code by email and must
                    enter it to finish signing in. Requires
                    <a href="/Company/EmailSettings">SMTP</a> to be configured for this company.
                </small>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-1"></i>Save Changes
            </button>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm bg-light border-0">
            <div class="card-body small">
                <h6 class="fw-bold mb-2"><i class="bi bi-info-circle text-primary me-2"></i>Other settings</h6>
                <ul class="ps-3 mb-2">
                    <li><a href="/Company/QuoteBranding">Quote branding</a> (logo, greeting, why-book-with-us)</li>
                    <li><a href="/Company/NumberSeries">Number series</a> (lead/package/booking/invoice prefixes)</li>
                    <li><a href="/Company/EmailSettings">Email settings</a> (SMTP)</li>
                    <li><a href="/Company/VoucherDefaults">Voucher defaults</a> (check-in/out times, hotel note, policy)</li>
                </ul>
                <hr class="my-2" />
                <div class="text-muted">
                    Plan: <strong>@Model.PlanName</strong> · Status: <strong>@Model.Status</strong><br />
                    Max users: <strong>@Model.MaxUsers</strong>
                </div>
            </div>
        </div>
    </div>
</form>
