@model TravelERP.Core.Entities.Tenant.BankAccount
@{
    ViewData["Title"] = "Add Bank Account";
    var types = ViewBag.AccountTypes as string[] ?? [];
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-transparent border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-bank text-primary me-2"></i>Bank Details</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="BankName" class="form-label small fw-semibold">Bank Name <span class="text-danger">*</span></label>
                    <input asp-for="BankName" class="form-control" placeholder="e.g. HDFC Bank" autofocus />
                    <span asp-validation-for="BankName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="HolderName" class="form-label small fw-semibold">Account Holder <span class="text-danger">*</span></label>
                    <input asp-for="HolderName" class="form-control" placeholder="As per bank records" />
                    <span asp-validation-for="HolderName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountNumber" class="form-label small fw-semibold">Account Number <span class="text-danger">*</span></label>
                    <input asp-for="AccountNumber" class="form-control font-monospace" />
                    <span asp-validation-for="AccountNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="IfscCode" class="form-label small fw-semibold">IFSC Code</label>
                    <input asp-for="IfscCode" class="form-control text-uppercase font-monospace" maxlength="20" placeholder="e.g. HDFC0001234" />
                </div>
                <div class="col-md-3">
                    <label asp-for="AccountType" class="form-label small fw-semibold">Account Type</label>
                    <select asp-for="AccountType" class="form-select">
                        <option value="">— Select —</option>
                        @foreach (var t in types)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Branch" class="form-label small fw-semibold">Branch</label>
                    <input asp-for="Branch" class="form-control" placeholder="e.g. Andheri West, Mumbai" />
                </div>
                <div class="col-md-6">
                    <label asp-for="UpiId" class="form-label small fw-semibold">UPI ID</label>
                    <input asp-for="UpiId" class="form-control font-monospace" placeholder="e.g. company@hdfcbank" />
                </div>
                <div class="col-md-12">
                    <div class="form-check form-switch">
                        <input asp-for="IsDefault" class="form-check-input" role="switch" />
                        <label asp-for="IsDefault" class="form-check-label small">
                            <i class="bi bi-star me-1"></i>Set as default account for invoices
                        </label>
                    </div>
                    <p class="text-muted small mb-0 mt-1">Only one account can be default — toggling this will unset any other default.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a href="/BankAccounts" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-1"></i>Save Bank Account
        </button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
